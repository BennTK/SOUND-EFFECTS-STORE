  .af-freq__preview-seg.af-active{background:#c9a84c}
  .af-freq__preview-dates{display:flex;justify-content:space-between}
  .af-freq__preview-dates span{font-size:0.6rem;color:#222}

  /* ── Payout form section ── */
  .af-payout__form-section{background:#0d0d0d;border:1px solid #1a1a1a;border-radius:10px;padding:2rem}
