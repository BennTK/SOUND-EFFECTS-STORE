<!-- ═══ WAITLIST FORM ═══ -->
<section class="af-apply" id="apply">
  <div class="af-container">
    <span class="af-cs-inline-pill">Coming Soon</span>
    <p class="af-eyebrow" style="margin-top:1rem">Be First in Line</p>
    <h2 class="af-section-title">Join the Waitlist</h2>
    <p class="af-section-sub">The programme isn't open yet — drop your details below and you'll be first to know when we launch, with priority access guaranteed.</p>

    <div class="af-apply__card">
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <div class="af-success">
            <div class="af-success__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h3 class="af-success__title">You're on the list!</h3>
            <p class="af-success__body">We'll email you the moment the programme opens — with priority access ahead of the public.</p>
          </div>
        {% else %}

        <input type="hidden" name="contact[subject]" value="Affiliate Waitlist Sign-Up">

        <div class="af-form__grid">
          <div class="af-form__field">
            <label class="af-form__label">Full Name *</label>
            <input type="text" name="contact[name]" class="af-form__input" placeholder="Your full name" required>
          </div>
          <div class="af-form__field">
            <label class="af-form__label">Email Address *</label>
            <input type="email" name="contact[email]" class="af-form__input" placeholder="you@example.com" required>
          </div>
          <div class="af-form__field af-form__field--full">
            <label class="af-form__label">Primary Platform URL</label>
            <input type="url" name="contact[body_platform]" class="af-form__input" placeholder="https://youtube.com/yourchannel or your website">
          </div>
          <div class="af-form__field">
            <label class="af-form__label">Audience / Follower Size</label>
            <select name="contact[body_audience]" class="af-form__input af-form__select">
              <option value="">Select range</option>
              <option>Under 1,000</option>
              <option>1,000 – 10,000</option>
              <option>10,000 – 50,000</option>
              <option>50,000 – 250,000</option>
              <option>250,000+</option>
            </select>
          </div>
          <div class="af-form__field">
            <label class="af-form__label">Content Type</label>
            <select name="contact[body_content_type]" class="af-form__input af-form__select">
              <option value="">Select type</option>
              <option>YouTube — Filmmaking / Cinematic</option>
              <option>YouTube — Gaming</option>
              <option>YouTube — Tutorial / Education</option>
              <option>Instagram / TikTok</option>
              <option>Podcast / Audio</option>
              <option>Blog / Newsletter</option>
              <option>Other</option>
            </select>
          </div>
          <div class="af-form__field af-form__field--full">
            <label class="af-form__label">Anything else you'd like us to know? (optional)</label>
            <textarea name="contact[body]" class="af-form__input af-form__textarea" placeholder="Tell us about your audience or how you plan to promote..." rows="3"></textarea>
          </div>
        </div>

        <button type="submit" class="af-btn af-btn--gold af-btn--lg">Reserve My Spot</button>
        <p class="af-apply__note">No commitment. We'll never share your details. Priority access guaranteed on launch.</p>

        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

<!-- ═══ PAYOUT REQUEST ═══ -->
