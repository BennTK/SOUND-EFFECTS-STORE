<script>
(function () {
  var refs    = document.getElementById('calc-referrals');
  var conv    = document.getElementById('calc-conv');
  var price   = document.getElementById('calc-price');
  if (!refs || !conv || !price) return;

  var refsVal    = document.getElementById('calc-referrals-val');
  var convVal    = document.getElementById('calc-conv-val');
  var priceVal   = document.getElementById('calc-price-val');
  var salesEl    = document.getElementById('calc-sales');
  var monthlyEl  = document.getElementById('calc-monthly');
  var annualEl   = document.getElementById('calc-annual');

  function fmt(n) { return n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 }); }
  function fmtUSD(n) { return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }

  function update() {
    var r = parseInt(refs.value, 10);
    var c = parseFloat(conv.value);
    var p = parseInt(price.value, 10);

    refsVal.textContent  = fmt(r);
    convVal.textContent  = c + '%';
    priceVal.textContent = '$' + p;

    var sales   = Math.round(r * (c / 100));
    var monthly = sales * p * 0.5;
    var annual  = monthly * 12;

    salesEl.textContent   = fmt(sales);
    monthlyEl.textContent = fmtUSD(monthly);
    annualEl.textContent  = fmtUSD(annual);
  }

  refs.addEventListener('input', update);
  conv.addEventListener('input', update);
  price.addEventListener('input', update);
  update();
})();

// ── Payout frequency picker ──
var currentFreq = 'weekly';

function selectFreq(freq) {
  currentFreq = freq;
  var weeklyCard  = document.getElementById('freq-weekly');
  var monthlyCard = document.getElementById('freq-monthly');
  var checkW      = document.getElementById('check-weekly');
  var checkM      = document.getElementById('check-monthly');
  var hiddenFreq  = document.getElementById('hidden-frequency');
  var freqDisplay = document.getElementById('freq-display');
  var previewLbl  = document.getElementById('preview-freq-label');
  var dates       = document.getElementById('preview-dates');

  if (freq === 'weekly') {
    weeklyCard.classList.add('af-freq__card--active');
    monthlyCard.classList.remove('af-freq__card--active');
    checkW.style.opacity = '1';
    checkM.style.opacity = '0';
    if (hiddenFreq)  hiddenFreq.value  = 'Weekly';
    if (freqDisplay) freqDisplay.value = 'Weekly — every Monday';
    if (previewLbl)  previewLbl.textContent = 'Weekly · paid every Monday';
    if (dates) dates.innerHTML = '<span>Week 1</span><span>Week 2</span><span>Week 3</span><span>Week 4</span>';
  } else {
    monthlyCard.classList.add('af-freq__card--active');
    weeklyCard.classList.remove('af-freq__card--active');
    checkM.style.opacity = '1';
    checkW.style.opacity = '0';
    if (hiddenFreq)  hiddenFreq.value  = 'Monthly';
    if (freqDisplay) freqDisplay.value = 'Monthly — 1st of each month';
    if (previewLbl)  previewLbl.textContent = 'Monthly · paid on the 1st';
    if (dates) dates.innerHTML = '<span>Jan</span><span>Feb</span><span>Mar</span><span>Apr</span>';
  }
  updatePreviewBar();
}

function updatePreviewBar() {
  var amountInput = document.getElementById('payout-amount-input');
  var amount = amountInput ? parseFloat(amountInput.value) || 0 : 0;
  var segs = [
    document.getElementById('preview-bar-1'),
    document.getElementById('preview-bar-2'),
    document.getElementById('preview-bar-3'),
    document.getElementById('preview-bar-4')
  ];
  if (!segs[0]) return;

  if (currentFreq === 'weekly') {
    var perWeek = amount / 4;
    var active = perWeek >= 50 ? 4 : Math.floor(amount / 50);
    segs.forEach(function(s, i) {
      s.classList.toggle('af-active', i < active);
      s.style.flex = '1';
    });
  } else {
    segs.forEach(function(s, i) {
      s.classList.toggle('af-active', i === 0 && amount >= 50);
      s.style.flex = i === 0 ? '4' : '1';
      s.style.opacity = i === 0 ? '1' : '0.15';
    });
  }
}

var amtInput = document.getElementById('payout-amount-input');
if (amtInput) amtInput.addEventListener('input', updatePreviewBar);
updatePreviewBar();
</script>
