<!-- Sonority Sound — Affiliate Programme Page -->

<!-- ═══ HERO ═══ -->
<section class="af-hero">
  <div class="af-hero__glow"></div>
  <div class="af-container">
    <p class="af-eyebrow">Affiliate Programme</p>
    <h1 class="af-hero__title">Earn <span class="af-gold">50%</span> on Every Sale</h1>
    <p class="af-hero__sub">Promote Sonority Sound to your audience and earn half of every sale — forever. No cap. No expiry. Just recurring income for content you already create.</p>
    <div class="af-hero__ctas">
      <a href="#apply" class="af-btn af-btn--gold">Apply Now — It's Free</a>
      <a href="#calculator" class="af-btn af-btn--outline">Calculate Your Earnings</a>
    </div>
    <p class="af-hero__note">Approved within 48 hours · Payouts every month · No minimum audience size</p>
  </div>
</section>

<!-- ═══ STATS STRIP ═══ -->
<div class="af-stats">
  <div class="af-container">
    <div class="af-stats__grid">
      <div class="af-stat">
        <span class="af-stat__num">50%</span>
        <span class="af-stat__label">Commission Rate</span>
      </div>
      <div class="af-stat">
        <span class="af-stat__num">30</span>
        <span class="af-stat__label">Day Cookie Window</span>
      </div>
      <div class="af-stat">
        <span class="af-stat__num">$50</span>
        <span class="af-stat__label">Minimum Payout</span>
      </div>
      <div class="af-stat">
        <span class="af-stat__num">∞</span>
        <span class="af-stat__label">No Earnings Cap</span>
      </div>
    </div>
  </div>
</div>

<!-- ═══ HOW IT WORKS ═══ -->
<section class="af-how">
  <div class="af-container">
    <p class="af-eyebrow">How It Works</p>
    <h2 class="af-section-title">Four steps from apply to payday</h2>
    <div class="af-steps">
      <div class="af-step">
        <div class="af-step__num">01</div>
        <div class="af-step__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </div>
        <h3 class="af-step__title">Apply</h3>
        <p class="af-step__desc">Fill in the form below. Tell us about your platform, audience, and how you plan to promote. Approved within 48 hours.</p>
      </div>
      <div class="af-step__arrow">→</div>
      <div class="af-step">
        <div class="af-step__num">02</div>
        <div class="af-step__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
        </div>
        <h3 class="af-step__title">Get Your Link</h3>
        <p class="af-step__desc">Receive your unique referral link and tracking dashboard. Share it anywhere — YouTube, Instagram, TikTok, your website.</p>
      </div>
      <div class="af-step__arrow">→</div>
      <div class="af-step">
        <div class="af-step__num">03</div>
        <div class="af-step__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3 class="af-step__title">Track in Real Time</h3>
        <p class="af-step__desc">Watch your clicks, conversions, and commissions build up in your affiliate dashboard — updated live every time a sale comes through.</p>
      </div>
      <div class="af-step__arrow">→</div>
      <div class="af-step">
        <div class="af-step__num">04</div>
        <div class="af-step__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
        </div>
        <h3 class="af-step__title">Get Paid</h3>
        <p class="af-step__desc">Request a payout once you hit $50. We process via bank transfer or PayPal within 7 business days, every month.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ EARNINGS CALCULATOR ═══ -->
<section class="af-calc" id="calculator">
  <div class="af-container">
    <p class="af-eyebrow">Earnings Calculator</p>
    <h2 class="af-section-title">See what you could earn</h2>
    <p class="af-section-sub">Adjust the sliders to match your audience and see your potential monthly income update in real time.</p>

    <div class="af-calc__card">
      <div class="af-calc__inputs">

        <div class="af-calc__field">
          <div class="af-calc__field-header">
            <label class="af-calc__label">Monthly Referrals (visitors sent)</label>
            <span class="af-calc__val" id="calc-referrals-val">1,000</span>
          </div>
          <input type="range" class="af-range" id="calc-referrals" min="100" max="50000" step="100" value="1000">
          <div class="af-range__ticks"><span>100</span><span>10k</span><span>25k</span><span>50k</span></div>
        </div>

        <div class="af-calc__field">
          <div class="af-calc__field-header">
            <label class="af-calc__label">Conversion Rate (%)</label>
            <span class="af-calc__val" id="calc-conv-val">2%</span>
          </div>
          <input type="range" class="af-range" id="calc-conv" min="0.5" max="10" step="0.5" value="2">
          <div class="af-range__ticks"><span>0.5%</span><span>3%</span><span>6%</span><span>10%</span></div>
        </div>

        <div class="af-calc__field">
          <div class="af-calc__field-header">
            <label class="af-calc__label">Average Pack Price (USD)</label>
            <span class="af-calc__val" id="calc-price-val">$19</span>
          </div>
          <input type="range" class="af-range" id="calc-price" min="9" max="79" step="1" value="19">
          <div class="af-range__ticks"><span>$9</span><span>$29</span><span>$49</span><span>$79</span></div>
        </div>

      </div>

      <div class="af-calc__results">
        <div class="af-calc__result-group">
          <div class="af-calc__result">
            <span class="af-calc__result-label">Sales / Month</span>
            <span class="af-calc__result-num" id="calc-sales">20</span>
          </div>
          <div class="af-calc__result af-calc__result--feature">
            <span class="af-calc__result-label">Your Monthly Earnings</span>
            <span class="af-calc__result-num af-gold" id="calc-monthly">$190</span>
          </div>
          <div class="af-calc__result">
            <span class="af-calc__result-label">Annual Earnings</span>
            <span class="af-calc__result-num" id="calc-annual">$2,280</span>
          </div>
        </div>
        <p class="af-calc__disclaimer">Based on 50% commission rate. Estimates only — actual results depend on your audience engagement.</p>
        <a href="#apply" class="af-btn af-btn--gold" style="width:100%;justify-content:center;margin-top:1.5rem">Apply Now &rarr;</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══ EARNINGS TABLE ═══ -->
