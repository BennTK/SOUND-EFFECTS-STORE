            </div>
            <div class="af-payout__info-item">
              <div class="af-payout__info-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
              <div><strong>Minimum $50 per payout</strong><br>Balances under $50 roll forward automatically</div>
            </div>
            <div class="af-payout__support">
              Questions? Email <a href="mailto:affiliates@spectrasound.com">affiliates@spectrasound.com</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    {% else %}

    <!-- NOT LOGGED IN STATE -->
    <div class="af-payout__gate">
      <div class="af-payout__gate-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
