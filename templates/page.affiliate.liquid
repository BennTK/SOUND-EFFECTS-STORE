                </div>
              </div>
              <button type="submit" class="af-btn af-btn--gold af-btn--lg" style="margin-top:0.5rem">Request Payout &amp; Invoice</button>
              {% endif %}
            {% endform %}
          </div>

          <div class="af-payout__info">
            <div class="af-payout__info-item">
              <div class="af-payout__info-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
              <div><strong>Weekly payouts</strong><br>Processed every Monday for the prior week's balance</div>
            </div>
            <div class="af-payout__info-item">
              <div class="af-payout__info-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
              <div><strong>Monthly payouts</strong><br>Processed on the 1st for the full prior month's balance</div>
            </div>
            <div class="af-payout__info-item">
              <div class="af-payout__info-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
