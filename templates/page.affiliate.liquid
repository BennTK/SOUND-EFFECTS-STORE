  .af-freq__example{background:#111;border:1px solid #1a1a1a;border-radius:5px;padding:0.6rem 0.85rem;display:flex;flex-direction:column;gap:0.15rem}
  .af-freq__example-label{font-size:0.6rem;text-transform:uppercase;letter-spacing:0.08em;color:#2a2a2a}
  .af-freq__example-val{font-size:0.82rem;font-weight:700;color:#c9a84c}
  .af-freq__example-val em{font-style:normal;color:#444;font-weight:400}

  /* ── Preview bar ── */
  .af-freq__preview{background:#0a0a0a;border:1px solid #161616;border-radius:6px;padding:1.25rem 1.5rem}
  .af-freq__preview-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem}
