            <td>$570 / yr</td>
          </tr>
          <tr>
            <td>20 sales</td>
            <td>$19</td>
            <td class="af-table__earn">$190 / mo</td>
            <td>$2,280 / yr</td>
          </tr>
          <tr>
            <td>50 sales</td>
            <td>$24</td>
            <td class="af-table__earn">$600 / mo</td>
            <td>$7,200 / yr</td>
          </tr>
          <tr class="af-table__row--highlight">
            <td>100 sales</td>
            <td>$29</td>
            <td class="af-table__earn">$1,450 / mo</td>
            <td>$17,400 / yr</td>
          </tr>
          <tr>
            <td>250 sales</td>
            <td>$29</td>
            <td class="af-table__earn">$3,625 / mo</td>
            <td>$43,500 / yr</td>
          </tr>
          <tr>
            <td>500 sales</td>
            <td>$34</td>
            <td class="af-table__earn">$8,500 / mo</td>
            <td>$102,000 / yr</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- ═══ PROGRAMME RULES ═══ -->
<section class="af-rules">
  <div class="af-container">
    <p class="af-eyebrow">Programme Rules</p>
    <h2 class="af-section-title">What you need to know</h2>
    <div class="af-rules__grid">
      <div class="af-rule">
        <div class="af-rule__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div><strong>30-day cookie</strong> — If someone clicks your link and buys within 30 days, you earn the commission.</div>
      </div>
      <div class="af-rule">
        <div class="af-rule__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div><strong>No self-referrals</strong> — Commissions cannot be earned on your own purchases.</div>
      </div>
      <div class="af-rule">
        <div class="af-rule__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div><strong>Refunds deducted</strong> — If a referred customer refunds within 30 days, the commission is reversed.</div>
      </div>
      <div class="af-rule">
        <div class="af-rule__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div><strong>Australian affiliates</strong> — An ABN is required for payouts to Australian residents (tax compliance).</div>
      </div>
      <div class="af-rule">
        <div class="af-rule__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div><strong>Honest promotion only</strong> — Paid ads bidding on our brand name, spam, and misleading claims are not permitted.</div>
      </div>
      <div class="af-rule">
        <div class="af-rule__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div><strong>Minimum payout $50</strong> — Balances below $50 roll over to the next month automatically.</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ APPLICATION FORM ═══ -->
<section class="af-apply" id="apply">
  <div class="af-container">
    <p class="af-eyebrow">Join the Programme</p>
    <h2 class="af-section-title">Apply in 2 minutes</h2>
    <p class="af-section-sub">We review every application personally. You'll hear back within 48 hours.</p>

    <div class="af-apply__card">
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <div class="af-success">
            <div class="af-success__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h3 class="af-success__title">Application received!</h3>
            <p class="af-success__body">We'll review your details and get back to you within 48 hours. Keep an eye on your inbox.</p>
          </div>
        {% else %}

        <input type="hidden" name="contact[subject]" value="Affiliate Programme Application">

        <div class="af-form__grid">
          <div class="af-form__field">
            <label class="af-form__label">Full Name *</label>
            <input type="text" name="contact[name]" class="af-form__input" placeholder="Your full name" required>
          </div>
          <div class="af-form__field">
            <label class="af-form__label">Email Address *</label>
            <input type="email" name="contact[email]" class="af-form__input" placeholder="you@example.com" required>
          </div>
          <div class="af-form__field af-form__field--full">
            <label class="af-form__label">Primary Platform URL *</label>
            <input type="url" name="contact[body_platform]" class="af-form__input" placeholder="https://youtube.com/yourchannel or your website" required>
          </div>
          <div class="af-form__field">
            <label class="af-form__label">Audience / Follower Size</label>
            <select name="contact[body_audience]" class="af-form__input af-form__select">
              <option value="">Select range</option>
              <option>Under 1,000</option>
              <option>1,000 – 10,000</option>
              <option>10,000 – 50,000</option>
              <option>50,000 – 250,000</option>
              <option>250,000+</option>
            </select>
          </div>
          <div class="af-form__field">
            <label class="af-form__label">Content Type</label>
            <select name="contact[body_content_type]" class="af-form__input af-form__select">
              <option value="">Select type</option>
              <option>YouTube — Filmmaking / Cinematic</option>
              <option>YouTube — Gaming</option>
              <option>YouTube — Tutorial / Education</option>
              <option>Instagram / TikTok</option>
              <option>Podcast / Audio</option>
              <option>Blog / Newsletter</option>
              <option>Other</option>
            </select>
          </div>
          <div class="af-form__field af-form__field--full">
            <label class="af-form__label">How do you plan to promote Sonority Sound? *</label>
            <textarea name="contact[body]" class="af-form__input af-form__textarea" placeholder="Tell us about your audience and how you'll feature our packs..." rows="4" required></textarea>
          </div>
          {% if localization.country.iso_code == 'AU' %}
          <div class="af-form__field af-form__field--full">
            <label class="af-form__label">Australian Business Number (ABN)</label>
            <input type="text" name="contact[body_abn]" class="af-form__input" placeholder="Required for Australian residents">
          </div>
          {% endif %}
        </div>

        <button type="submit" class="af-btn af-btn--gold af-btn--lg">Submit Application</button>
        <p class="af-apply__note">By applying you agree to our programme rules above. We'll never share your details.</p>

        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

<!-- ═══ PAYOUT REQUEST ═══ -->
<section class="af-payout" id="payout">
  <div class="af-container">
    <p class="af-eyebrow">Already an Affiliate?</p>
    <h2 class="af-section-title">Request a Payout</h2>
    <p class="af-section-sub">Once your balance reaches $50 you can request a payment. We process all payouts within 7 business days.</p>

    <div class="af-payout__grid">

      <div class="af-payout__card">
        <div class="af-payout__card-head">
          <div class="af-payout__card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          </div>
          <h3 class="af-payout__card-title">Request Invoice &amp; Payout</h3>
        </div>
        {% form 'contact' %}
          {% if form.posted_successfully? %}
            <div class="af-success af-success--small">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              <p>Payout request received! We'll process within 7 business days and send your invoice confirmation.</p>
            </div>
          {% else %}
          <input type="hidden" name="contact[subject]" value="Affiliate Payout Request">
          <div class="af-form__field" style="margin-bottom:1rem">
            <label class="af-form__label">Your Affiliate Email</label>
            <input type="email" name="contact[email]" class="af-form__input" placeholder="Email used on your affiliate account" required>
          </div>
          <div class="af-form__field" style="margin-bottom:1rem">
            <label class="af-form__label">Amount to Request (USD)</label>
            <input type="number" name="contact[body_amount]" class="af-form__input" placeholder="e.g. 145.00" min="50" step="0.01" required>
          </div>
          <div class="af-form__field" style="margin-bottom:1rem">
            <label class="af-form__label">Payment Method</label>
            <select name="contact[body_payment]" class="af-form__input af-form__select">
              <option>PayPal</option>
              <option>Bank Transfer (Australia)</option>
              <option>Bank Transfer (International)</option>
            </select>
          </div>
          <div class="af-form__field" style="margin-bottom:1rem">
            <label class="af-form__label">PayPal Email or Bank Details</label>
            <input type="text" name="contact[body_payment_details]" class="af-form__input" placeholder="PayPal email or BSB/Account number">
          </div>
          <div class="af-form__field" style="margin-bottom:1.5rem">
            <label class="af-form__label">Invoice Notes (optional)</label>
            <input type="text" name="contact[body]" class="af-form__input" placeholder="ABN, business name, or any notes for the invoice">
          </div>
          <button type="submit" class="af-btn af-btn--gold" style="width:100%;justify-content:center">Request Payout &amp; Invoice</button>
          {% endif %}
        {% endform %}
      </div>

      <div class="af-payout__info">
        <div class="af-payout__info-item">
          <div class="af-payout__info-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <div><strong>Processing time</strong><br>7 business days from request</div>
        </div>
        <div class="af-payout__info-item">
          <div class="af-payout__info-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></div>
          <div><strong>Payment methods</strong><br>PayPal or bank transfer</div>
        </div>
        <div class="af-payout__info-item">
          <div class="af-payout__info-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
          <div><strong>Invoice provided</strong><br>PDF invoice sent with every payout</div>
        </div>
        <div class="af-payout__info-item">
          <div class="af-payout__info-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
          <div><strong>Minimum $50</strong><br>Balances below $50 roll to next month</div>
        </div>
        <div class="af-payout__support">
          Questions? Email <a href="mailto:affiliates@sonoritysound.com">affiliates@sonoritysound.com</a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Base ── */
  .af-container{max-width:1100px;margin:0 auto;padding:0 2rem}
  .af-eyebrow{font-size:0.62rem;letter-spacing:0.22em;text-transform:uppercase;color:#c9a84c;font-weight:600;margin:0 0 0.85rem}
  .af-section-title{font-size:clamp(1.6rem,3.5vw,2.4rem);font-weight:900;color:#fff;letter-spacing:-0.03em;margin:0 0 1rem;line-height:1.1}
  .af-section-sub{font-size:0.88rem;color:#444;line-height:1.7;max-width:560px;margin:0 0 3rem}
  .af-gold{color:#c9a84c}

  /* ── Buttons ── */
  .af-btn{display:inline-flex;align-items:center;gap:0.5rem;font-family:inherit;font-size:0.82rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;border-radius:5px;padding:0.9rem 1.75rem;cursor:pointer;transition:background 0.2s,transform 0.15s,border-color 0.2s,color 0.2s;border:none}
  .af-btn--gold{background:#c9a84c;color:#0a0a0a}.af-btn--gold:hover{background:#d9b85c;transform:translateY(-1px)}
  .af-btn--outline{background:transparent;color:#666;border:1px solid #2a2a2a}.af-btn--outline:hover{border-color:#c9a84c;color:#c9a84c}
  .af-btn--lg{width:100%;justify-content:center;padding:1.1rem 2rem;font-size:0.88rem}

  /* ── Hero ── */
  .af-hero{background:#0a0a0a;padding:7rem 0 5rem;text-align:center;position:relative;overflow:hidden;border-bottom:1px solid #111}
  .af-hero__glow{position:absolute;top:-100px;left:50%;transform:translateX(-50%);width:900px;height:600px;background:radial-gradient(ellipse,rgba(201,168,76,0.07) 0%,transparent 65%);pointer-events:none}
  .af-hero .af-container{position:relative;z-index:1}
  .af-hero__title{font-size:clamp(2.8rem,8vw,6rem);font-weight:900;color:#fff;letter-spacing:-0.04em;line-height:1;margin:0 0 1.5rem}
  .af-hero__sub{font-size:1rem;color:#444;line-height:1.75;max-width:580px;margin:0 auto 2.5rem}
  .af-hero__ctas{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:1.5rem}
  .af-hero__note{font-size:0.72rem;color:#2a2a2a;letter-spacing:0.04em}

  /* ── Stats ── */
  .af-stats{background:#0d0d0d;border-top:1px solid #111;border-bottom:1px solid #111;padding:2.5rem 0}
  .af-stats__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0;text-align:center}
  .af-stat{padding:1.5rem;border-right:1px solid #161616}.af-stat:last-child{border-right:none}
  .af-stat__num{display:block;font-size:clamp(2rem,4vw,3rem);font-weight:900;color:#c9a84c;letter-spacing:-0.04em;line-height:1;margin-bottom:0.4rem}
  .af-stat__label{font-size:0.68rem;color:#333;text-transform:uppercase;letter-spacing:0.1em}

  /* ── How it works ── */
  .af-how{background:#0a0a0a;padding:6rem 0;border-bottom:1px solid #111}
  .af-steps{display:flex;align-items:flex-start;gap:0}
  .af-step{flex:1;padding:2rem;background:#0d0d0d;border:1px solid #161616;border-radius:8px;display:flex;flex-direction:column;gap:1rem}
  .af-step__arrow{font-size:1.2rem;color:#222;padding:0 0.5rem;margin-top:3.5rem;flex-shrink:0}
