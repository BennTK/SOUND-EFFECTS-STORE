<!-- Spectra Sound — Collection Page -->
<div class="sc-page">

  <!-- Page Header -->
  <div class="sc-header">
    <p class="sc-header__eyebrow">Spectra Sound</p>
    <h1 class="sc-header__title">{{ collection.title | default: 'Sound Effects' }}</h1>
    {% if collection.description != blank %}
      <p class="sc-header__desc">{{ collection.description }}</p>
    {% else %}
      <p class="sc-header__desc">Professionally recorded. Instant download. Commercial license included.</p>
    {% endif %}
    <div class="sc-header__meta">
      <span class="sc-header__count">
        {% if collection.products_count > 0 %}
          {{ collection.products_count }} packs available
        {% else %}
          Packs coming soon
        {% endif %}
      </span>
    </div>
  </div>

  <!-- ── Drone Fly Bys — Individual Packs ── -->
  <div class="sc-section">
    <div class="sc-section__header">
      <div class="sc-section__label">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
        Drone Fly Bys
      </div>
      <h2 class="sc-section__title">Individual Sound Packs</h2>
      <p class="sc-section__desc">Each pack captures a distinct environment — choose what fits your scene, or grab them all.</p>
    </div>

    <div class="sc-grid">

      {%- assign packs = "Forest & Trees,drone-fly-bys-forest,forest,Sounds for flights through dense woodland and towering forest canopies|Rocks & Cliffs,drone-fly-bys-rocks-cliffs,rocks,Sounds for flights across rugged cliff faces and exposed rocky terrain|Waterfalls,drone-fly-bys-waterfalls,water,Sounds for flights past cascading waterfalls and rushing rapids|Insects,drone-fly-bys-insects,insects,Alive buzzing ambience for low flights through insect-rich natural environments|Wind,drone-fly-bys-wind,wind,Open-air sounds for high-altitude and windswept location flights|Rivers & Lakes,drone-fly-bys-rivers-lakes,rivers,Sounds for flights along flowing waterways and open lake surfaces|Ocean & Waves,drone-fly-bys-ocean-waves,ocean,Sounds for flights along dramatic coastlines and open ocean|Grass & Fields,drone-fly-bys-grass-fields,grass,Sounds for low flights across open meadows and wide grass fields|Generic Whooshes,drone-fly-bys-whooshes,whoosh,Clean directional whooshes for any aerial flyby or fast pass|Generic Vehicles,drone-fly-bys-vehicles,vehicles,Vehicle passes for boats motorcycles 4WD and standard cars to enhance energy and realism in any action travel or lifestyle aerial scene|Arctic,drone-fly-bys-arctic,arctic,Sounds for flights across frozen tundra glaciers and towering ice structures|Buildings & Structures,drone-fly-bys-buildings-structures,buildings,Sounds for building dives structure passes and varied surface materials|Birds,drone-fly-bys-birds,birds,Species-accurate bird sounds from global regions to suit any nature aerial scene|Frogs,drone-fly-bys-frogs,frogs,Made for wetland damp and tropical climate scenes where biological atmosphere is essential|Desert,drone-fly-bys-desert,desert,Sounds for flights across vast desert plains rolling sand dunes and arid terrain|Drone Audio,drone-fly-bys-drone-audio,drone-sfx,Motor beeps propeller sounds and clean FPV fly-bys for any drone footage|Volcanic,drone-fly-bys-volcanic,volcanic,Sounds for flights across active lava fields volcanic craters and molten landscapes" | split: "|" -%}
      {%- for pack in packs -%}
        {%- assign parts = pack | split: "," -%}
        {%- assign pack_name = parts[0] -%}
        {%- assign pack_slug = parts[1] -%}
        {%- assign pack_class = parts[2] -%}
        {%- assign pack_tagline = parts[3] -%}
        <a href="/pages/{{ pack_slug }}" class="sc-card">
          <div class="sc-card__img-wrap">
            <div class="sc-card__img-placeholder sc-card__img-placeholder--{{ pack_class }}"></div>
            <div class="sc-card__overlay">
              <span class="sc-card__quick-btn">View Pack →</span>
            </div>
          </div>
          <div class="sc-card__info">
            <div>
              <p class="sc-card__name">{{ pack_name }}</p>
              <p class="sc-card__tagline">{{ pack_tagline }}</p>
              <p class="sc-card__category">Drone Fly Bys Collection</p>
            </div>
            <div class="sc-card__pricing">
              <span class="sc-card__price">From $19</span>
            </div>
          </div>
        </a>
      {%- endfor -%}

    </div>
  </div>

  <!-- ── Spacer / Divider ── -->
  <div class="sc-divider">
    <div class="sc-divider__line"></div>
    <span class="sc-divider__label">More Collections</span>
    <div class="sc-divider__line"></div>
  </div>

  <!-- ── Future Collections ── -->
  <div class="sc-section">
    <div class="sc-section__header">
      <div class="sc-section__label">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Coming Soon
      </div>
      <h2 class="sc-section__title">Creator Workspace Essentials</h2>
      <p class="sc-section__desc">Our next collection — essential sounds for content creators, editors, and podcasters. Launching soon.</p>
    </div>

    <div class="sc-grid sc-grid--future">
      <div class="sc-card sc-card--coming">
        <div class="sc-card__img-wrap">
          <div class="sc-card__img-placeholder sc-card__img-placeholder--future">
            <div class="sc-card__coming-label">Coming Soon</div>
          </div>
        </div>
        <div class="sc-card__info">
          <div>
            <p class="sc-card__name">Creator Workspace Essentials</p>
            <p class="sc-card__category">Future Collection</p>
          </div>
          <div class="sc-card__pricing">
            <span class="sc-card__price sc-card__price--tba">TBA</span>
          </div>
        </div>
      </div>

      <div class="sc-card sc-card--coming">
        <div class="sc-card__img-wrap">
          <div class="sc-card__img-placeholder sc-card__img-placeholder--future">
            <div class="sc-card__coming-label">Coming Soon</div>
          </div>
        </div>
        <div class="sc-card__info">
          <div>
            <p class="sc-card__name">More Packs Announced Shortly</p>
            <p class="sc-card__category">Future Collection</p>
          </div>
          <div class="sc-card__pricing">
            <span class="sc-card__price sc-card__price--tba">TBA</span>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>

<style>
  .sc-page {
    background: #0a0a0a;
    min-height: 100vh;
    padding: 4rem 2rem 6rem;
  }

  /* ── Header ── */
  .sc-header {
    max-width: 1100px;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .sc-header__eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #c9a84c;
    margin: 0 0 0.75rem;
  }

  .sc-header__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    line-height: 1.05;
  }

  .sc-header__desc {
    font-size: 0.95rem;
    color: #555;
    margin: 0 auto 1.25rem;
    max-width: 520px;
    line-height: 1.7;
  }

  .sc-header__meta {
    display: flex;
    justify-content: center;
  }

  .sc-header__count {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #333;
    border: 1px solid #1e1e1e;
    padding: 0.35rem 0.9rem;
    border-radius: 2px;
  }

  /* ── Section ── */
  .sc-section {
    max-width: 1100px;
    margin: 0 auto 4rem;
  }

  .sc-section__header {
    margin-bottom: 2rem;
  }

  .sc-section__label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #c9a84c;
    margin-bottom: 0.75rem;
  }

  .sc-section__title {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
  }

  .sc-section__desc {
    font-size: 0.85rem;
    color: #444;
    margin: 0;
    line-height: 1.6;
    max-width: 540px;
  }

  /* ── Grid ── */
  .sc-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  /* ── Card ── */
  .sc-card {
    display: block;
    text-decoration: none;
    background: #0f0f0f;
    border: 1px solid #1a1a1a;
    border-radius: 6px;
    overflow: hidden;
    transition: border-color 0.25s, transform 0.25s;
  }

  .sc-card:hover {
    border-color: rgba(201,168,76,0.25);
    transform: translateY(-3px);
  }

  .sc-card--coming {
    pointer-events: none;
    opacity: 0.5;
  }

  /* Image area */
  .sc-card__img-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .sc-card__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-size: cover;
    background-position: center;
    position: relative;
    transition: transform 0.4s ease;
  }

  .sc-card:hover .sc-card__img-placeholder {
    transform: scale(1.04);
  }

  /* Dark scrim so title text is always readable */
  .sc-card__img-placeholder::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.35);
    pointer-events: none;
  }

  /* Environment colour gradients as placeholders */
  .sc-card__img-placeholder--forest  { background: url('{{ "forest-trees-cover.jpg" | asset_url }}') center/cover no-repeat; }
  .sc-card__img-placeholder--rocks   { background: url('{{ "rocks-cliffs-cover.jpg" | asset_url }}') center/cover no-repeat; }
  .sc-card__img-placeholder--water   { background: linear-gradient(145deg, #080e18 0%, #0a1220 50%, #060c16 100%); }
  .sc-card__img-placeholder--insects { background: linear-gradient(145deg, #0e1208 0%, #141a0c 50%, #0a0e06 100%); }
  .sc-card__img-placeholder--wind    { background: linear-gradient(145deg, #0c0e14 0%, #10121c 50%, #080a10 100%); }
  .sc-card__img-placeholder--rivers  { background: linear-gradient(145deg, #060e18 0%, #08101e 50%, #040c14 100%); }
  .sc-card__img-placeholder--ocean   { background: url('{{ "drone-ocean.jpg" | asset_url }}') center/cover no-repeat; }
  .sc-card__img-placeholder--grass   { background: linear-gradient(145deg, #081408 0%, #0c1c0c 50%, #061006 100%); }
  .sc-card__img-placeholder--whoosh    { background: linear-gradient(145deg, #100c14 0%, #18101e 50%, #0e0a12 100%); }
  .sc-card__img-placeholder--vehicles  { background: linear-gradient(145deg, #100e08 0%, #18160c 50%, #0e0c08 100%); }
  .sc-card__img-placeholder--arctic    { background: linear-gradient(145deg, #060c18 0%, #0a1224 50%, #060e1c 100%); }
  .sc-card__img-placeholder--buildings { background: linear-gradient(145deg, #0e0e0c 0%, #161614 50%, #0c0c0a 100%); }
  .sc-card__img-placeholder--birds     { background: linear-gradient(145deg, #080e06 0%, #0e160a 50%, #060c04 100%); }
  .sc-card__img-placeholder--frogs     { background: linear-gradient(145deg, #050e07 0%, #081408 50%, #040c06 100%); }
  .sc-card__img-placeholder--desert    { background: linear-gradient(145deg, #160e04 0%, #1e1406 50%, #140c04 100%); }
  .sc-card__img-placeholder--drone-sfx { background: linear-gradient(145deg, #080a12 0%, #0e1020 50%, #060810 100%); }
  .sc-card__img-placeholder--volcanic  { background: linear-gradient(145deg, #180a04 0%, #200c06 50%, #140804 100%); }
  .sc-card__img-placeholder--future    { background: linear-gradient(145deg, #0e0e0e 0%, #141414 50%, #0a0a0a 100%); }

  /* Add image icon overlay on placeholder */
  /* Centered title inside thumbnail */
  .sc-card__thumb-title {
    position: relative;
    z-index: 2;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    text-align: center;
    padding: 0 1rem;
    text-shadow: 0 2px 12px rgba(0,0,0,0.8);
  }

  .sc-card__coming-label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #333;
    border: 1px solid #1e1e1e;
    padding: 0.35rem 0.85rem;
    border-radius: 2px;
    position: relative;
    z-index: 1;
  }

  /* Hover overlay */
  .sc-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
    opacity: 0;
    transition: opacity 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sc-card:hover .sc-card__overlay { opacity: 1; }

  .sc-card__quick-btn {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0a0a0a;
    background: #c9a84c;
    padding: 0.55rem 1.25rem;
    border-radius: 3px;
    transition: background 0.2s;
  }

  .sc-card__quick-btn:hover { background: #e0bc6a; }

  /* Card info */
  .sc-card__info {
    padding: 1rem 1.25rem 1.25rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.75rem 1rem;
    align-items: start;
  }

  .sc-card__info > div:first-child { grid-column: 1; }

  .sc-card__name {
    font-size: 0.88rem;
    font-weight: 600;
    color: #ccc;
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }

  .sc-card__tagline {
    font-size: 0.7rem;
    color: #444;
    line-height: 1.5;
    margin: 0 0 0.4rem;
  }

  .sc-card__category {
    font-size: 0.58rem;
    color: #282828;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
  }

  .sc-card__pricing { text-align: right; flex-shrink: 0; grid-column: 2; grid-row: 1; }

  .sc-card__price {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: #c9a84c;
  }

  .sc-card__price--tba {
    font-size: 0.75rem;
    color: #333;
    letter-spacing: 0.1em;
  }

  /* ── Divider ── */
  .sc-divider {
    max-width: 1100px;
    margin: 0 auto 4rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .sc-divider__line {
    flex: 1;
    height: 1px;
    background: #1a1a1a;
  }

  .sc-divider__label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #2e2e2e;
    white-space: nowrap;
  }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .sc-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .sc-page { padding: 3rem 1rem 4rem; }
    .sc-grid { grid-template-columns: 1fr; }
  }
</style>
