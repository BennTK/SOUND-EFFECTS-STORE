          <a href="mailto:benntkmanagement@gmail.com?subject=Wrong%20Product%20Purchased" class="sp-tag">Wrong product</a>
          <a href="mailto:benntkmanagement@gmail.com?subject=Teams%20%26%20Studio%20License%20Enquiry" class="sp-tag">Studio license</a>
          <a href="mailto:benntkmanagement@gmail.com?subject=Technical%20Issue" class="sp-tag">Technical issue</a>
          <a href="mailto:benntkmanagement@gmail.com?subject=Pack%20Update%20Enquiry" class="sp-tag">Pack update</a>
        </div>
      </div>

      <a href="/collections/sound-effects" class="sp-contact__browse">
        Browse Collections
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
