<!-- Spectra Sound — Bundles Page -->
<div class="bn-page">
  <div class="bn-glow"></div>

  <!-- ══ PAGE HEADER ══ -->
  <div class="bn-header">
    <p class="bn-eyebrow">Spectra Sound</p>
    <h1 class="bn-title">Bundles</h1>
    <p class="bn-desc">Get more for less. Each bundle combines multiple packs into one complete download — the smartest way to build your sound library.</p>
    <div class="bn-header__tags">
      <span class="bn-tag"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Commercial license included</span>
      <span class="bn-tag"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Instant download</span>
      <span class="bn-tag"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Royalty-free forever</span>
    </div>
  </div>

  <!-- ══ DRONE FLY BYS — BUNDLES ══ -->
  <div class="bn-section">
    <div class="bn-section__head">
      <div class="bn-section__label">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
        Drone Fly Bys
      </div>
      <h2 class="bn-section__title">Drone Fly Bys Bundles</h2>
      <p class="bn-section__desc">Multiple environments in a single download — save up to 40% versus buying individual packs.</p>
    </div>

    <div class="bn-grid">

      <!-- ── 1. Drone Fly Bys Essentials ── -->
      <div class="bn-card bn-card--soon">
        <div class="bn-card__media bn-card__media--placeholder">
          <span class="bn-card__badge">Bundle</span>
          <span class="bn-card__count">9 Packs</span>
        </div>
        <div class="bn-card__body">
          <p class="bn-card__collection">Drone Fly Bys Collection</p>
          <h3 class="bn-card__name">Drone Fly Bys Essentials Bundle</h3>
          <p class="bn-card__detail">Nine Drone Fly Bys environments covering the most common aerial flight scenarios in a single download. The ideal starting point for creators who need broad, versatile coverage across a wide range of locations and conditions.</p>
          <div class="bn-card__includes">
            <span class="bn-card__inc-label">9 Packs Included</span>
            <div class="bn-card__inc-tags">
              <span>Forest & Trees</span>
              <span>Rocks & Cliffs</span>
              <span>Ocean & Waves</span>
              <span>Wind</span>
              <span>Rivers & Lakes</span>
              <span>Waterfalls</span>
              <span>Grass & Fields</span>
              <span>Generic Whooshes</span>
              <span>Generic Vehicles</span>
            </div>
          </div>
          <div class="bn-card__foot">
            <div class="bn-card__price-wrap">
              <span class="bn-card__price bn-card__price--tba">Coming Soon</span>
              <span class="bn-card__save bn-card__save--muted">Save 35%</span>
            </div>
            <span class="bn-card__btn bn-card__btn--muted">Coming Soon</span>
          </div>
        </div>
      </div>

      <!-- ── 2. Drone Fly Bys Nature Bundle ── -->
      <div class="bn-card bn-card--soon">
        <div class="bn-card__media bn-card__media--placeholder">
          <span class="bn-card__badge">Bundle</span>
          <span class="bn-card__count">8 Packs</span>
        </div>
        <div class="bn-card__body">
          <p class="bn-card__collection">Drone Fly Bys Collection</p>
          <h3 class="bn-card__name">Drone Fly Bys Nature Bundle</h3>
          <p class="bn-card__detail">Eight Drone Fly Bys environments capturing the most vital sounds for immersive nature drone flights in a single download. The ideal choice for creators who need rich, organic coverage across forests, coastlines, waterways, and open terrain.</p>
          <div class="bn-card__includes">
            <span class="bn-card__inc-label">8 Packs Included</span>
            <div class="bn-card__inc-tags">
              <span>Forest & Trees</span>
              <span>Rocks & Cliffs</span>
              <span>Ocean & Waves</span>
              <span>Rivers & Lakes</span>
              <span>Waterfalls</span>
              <span>Insects</span>
              <span>Wind</span>
              <span>Grass & Fields</span>
            </div>
          </div>
          <div class="bn-card__foot">
            <div class="bn-card__price-wrap">
              <span class="bn-card__price bn-card__price--tba">Coming Soon</span>
              <span class="bn-card__save bn-card__save--muted">Save 35%</span>
            </div>
            <span class="bn-card__btn bn-card__btn--muted">Coming Soon</span>
          </div>
        </div>
      </div>

      <!-- ── 3. Complete Collection ── -->
      <div class="bn-card bn-card--soon">
        <div class="bn-card__media bn-card__media--placeholder">
          <span class="bn-card__badge">Bundle</span>
          <span class="bn-card__count">17 Packs</span>
        </div>
        <div class="bn-card__body">
          <p class="bn-card__collection">Drone Fly Bys Collection</p>
          <h3 class="bn-card__name">Drone Fly Bys Complete Collection</h3>
          <p class="bn-card__detail">All seventeen Drone Fly Bys environments across every terrain and condition in a single download. The definitive choice for creators who demand total coverage and never want to be caught without the right sound for a scene.</p>
          <div class="bn-card__includes">
            <span class="bn-card__inc-label">17 Packs Included</span>
            <div class="bn-card__inc-tags">
              <span>Forest & Trees</span>
              <span>Rocks & Cliffs</span>
              <span>Ocean & Waves</span>
              <span>Wind</span>
              <span>Rivers & Lakes</span>
              <span>Waterfalls</span>
              <span>Grass & Fields</span>
              <span>Insects</span>
              <span>Generic Whooshes</span>
              <span>Generic Vehicles</span>
              <span>+ 7 more</span>
            </div>
          </div>
          <div class="bn-card__foot">
            <div class="bn-card__price-wrap">
              <span class="bn-card__price bn-card__price--tba">Coming Soon</span>
              <span class="bn-card__save bn-card__save--muted">Best Value</span>
            </div>
            <span class="bn-card__btn bn-card__btn--muted">Coming Soon</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ══ DIVIDER ══ -->
  <div class="bn-divider">
    <div class="bn-divider__line"></div>
    <span class="bn-divider__label">More Collections</span>
    <div class="bn-divider__line"></div>
  </div>

  <!-- ══ COMING SOON COLLECTIONS ══ -->
  <div class="bn-section bn-section--soon">
    <div class="bn-section__head">
      <div class="bn-section__label bn-section__label--soon">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Coming Soon
      </div>
      <h2 class="bn-section__title">More Bundles on the Way</h2>
      <p class="bn-section__desc">We're building bundles across every collection we release. Sign up to be notified when new bundles drop.</p>
    </div>

    <div class="bn-grid">

      <div class="bn-card bn-card--soon bn-card--teaser">
        <div class="bn-card__media bn-card__media--teaser">
          <div class="bn-card__img bn-card__img--urban"></div>
          <span class="bn-card__badge bn-card__badge--soon">Coming Soon</span>
        </div>
        <div class="bn-card__body">
          <p class="bn-card__collection">Urban Environments</p>
          <h3 class="bn-card__name">Urban & City Bundle</h3>
          <p class="bn-card__detail">City streets, traffic, construction, crowds — everything you need for urban aerial and ground-level footage.</p>
          <div class="bn-card__inc-tags bn-card__inc-tags--muted" style="margin-top:0.75rem">
            <span>Street Level</span><span>Traffic</span><span>Construction</span><span>Crowds</span>
          </div>
          <div class="bn-card__foot" style="margin-top:1.25rem">
            <span class="bn-card__price bn-card__price--tba">Coming Soon</span>
            <span class="bn-card__btn bn-card__btn--muted">Notify Me</span>
          </div>
        </div>
      </div>

      <div class="bn-card bn-card--soon bn-card--teaser">
        <div class="bn-card__media bn-card__media--teaser">
          <div class="bn-card__img bn-card__img--creator"></div>
          <span class="bn-card__badge bn-card__badge--soon">Coming Soon</span>
        </div>
        <div class="bn-card__body">
          <p class="bn-card__collection">Creator Workspace</p>
          <h3 class="bn-card__name">Creator Essentials Bundle</h3>
          <p class="bn-card__detail">UI sounds, transitions, notifications, and ambiences built specifically for content creators and streamers.</p>
          <div class="bn-card__inc-tags bn-card__inc-tags--muted" style="margin-top:0.75rem">
            <span>UI & Transitions</span><span>Notifications</span><span>Ambience</span><span>Stingers</span>
          </div>
          <div class="bn-card__foot" style="margin-top:1.25rem">
            <span class="bn-card__price bn-card__price--tba">Coming Soon</span>
            <span class="bn-card__btn bn-card__btn--muted">Notify Me</span>
          </div>
        </div>
      </div>

      <div class="bn-card bn-card--soon bn-card--teaser">
        <div class="bn-card__media bn-card__media--teaser">
          <div class="bn-card__img bn-card__img--cinematic"></div>
          <span class="bn-card__badge bn-card__badge--soon">Coming Soon</span>
        </div>
        <div class="bn-card__body">
          <p class="bn-card__collection">Cinematic</p>
          <h3 class="bn-card__name">Cinematic Impact Bundle</h3>
          <p class="bn-card__detail">Whooshes, impacts, risers, and atmospheres designed for trailers, film, and high-production content.</p>
          <div class="bn-card__inc-tags bn-card__inc-tags--muted" style="margin-top:0.75rem">
            <span>Impacts</span><span>Risers</span><span>Whooshes</span><span>Atmospheres</span>
          </div>
          <div class="bn-card__foot" style="margin-top:1.25rem">
            <span class="bn-card__price bn-card__price--tba">Coming Soon</span>
            <span class="bn-card__btn bn-card__btn--muted">Notify Me</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Notify strip -->
    <div class="bn-notify">
      <div class="bn-notify__inner">
        <div>
          <p class="bn-notify__title">Get notified when new bundles drop</p>
          <p class="bn-notify__sub">Join 1,243+ creators already on the list.</p>
        </div>
        {% form 'customer' %}
          {% if form.posted_successfully? %}
            <p class="bn-notify__thanks">You're on the list! We'll let you know first.</p>
          {% else %}
            <input type="hidden" name="contact[tags]" value="newsletter,bundle-notify">
            <div class="bn-notify__form">
              <input type="email" name="contact[email]" class="bn-notify__input" placeholder="your@email.com" required autocomplete="email">
              <button type="submit" class="bn-notify__btn">Notify Me</button>
            </div>
          {% endif %}
        {% endform %}
      </div>
    </div>
  </div>

  <!-- ══ WHY BUNDLE ══ -->
  <div class="bn-why">
    <div class="bn-why__inner">
      <p class="bn-eyebrow">Why Bundle?</p>
      <div class="bn-why__grid">
        <div class="bn-why__item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.4"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          <h3>Better value</h3>
          <p>Bundles are priced well below buying each pack individually — the more you need, the more you save.</p>
        </div>
        <div class="bn-why__item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.4"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
          <h3>One download</h3>
          <p>Everything arrives in a single organised download — no managing multiple purchases or separate folders.</p>
        </div>
        <div class="bn-why__item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.4"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <h3>Full coverage</h3>
          <p>Never get caught without the right sound — bundles give you complete environmental coverage for any scene.</p>
        </div>
      </div>
    </div>
  </div>

</div>

<style>
  .bn-page{background:#0a0a0a;min-height:100vh;position:relative;overflow-x:hidden;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
  .bn-glow{position:absolute;top:-80px;left:50%;transform:translateX(-50%);width:900px;height:500px;background:radial-gradient(ellipse,rgba(201,168,76,0.07) 0%,transparent 65%);pointer-events:none;z-index:0}

  /* ── Header ── */
  .bn-header{max-width:1100px;margin:0 auto;padding:5rem 2rem 4rem;text-align:center;position:relative;z-index:1}
  .bn-eyebrow{font-size:0.62rem;letter-spacing:0.28em;text-transform:uppercase;color:#c9a84c;margin:0 0 1rem;font-weight:600}
  .bn-title{font-size:clamp(2.5rem,6vw,4.5rem);font-weight:900;color:#fff;letter-spacing:-0.04em;line-height:1;margin:0 0 1.25rem}
  .bn-desc{font-size:0.95rem;color:#3e3e3e;line-height:1.75;margin:0 auto 2rem;max-width:520px}
  .bn-header__tags{display:flex;justify-content:center;gap:0.75rem;flex-wrap:wrap}
  .bn-tag{display:inline-flex;align-items:center;gap:0.45rem;font-size:0.65rem;letter-spacing:0.14em;text-transform:uppercase;color:#2a2a2a;border:1px solid #161616;padding:0.4rem 0.9rem;border-radius:3px}

  /* ── Section ── */
  .bn-section{max-width:1100px;margin:0 auto;padding:0 2rem 5rem;position:relative;z-index:1}
  .bn-section--soon{padding-bottom:0}
  .bn-section__head{margin-bottom:2.5rem}
  .bn-section__label{display:inline-flex;align-items:center;gap:0.5rem;font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:#c9a84c;font-weight:700;margin-bottom:0.85rem}
  .bn-section__label--soon{color:#333}
  .bn-section__title{font-size:clamp(1.5rem,3vw,2rem);font-weight:900;color:#fff;letter-spacing:-0.03em;margin:0 0 0.6rem;line-height:1.1}
  .bn-section__desc{font-size:0.85rem;color:#3a3a3a;line-height:1.7;margin:0;max-width:520px}

  /* ── Grid — 3 per row ── */
  .bn-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem}

  /* ── Card ── */
  .bn-card{display:block;text-decoration:none;background:#0d0d0d;border:1px solid #1a1a1a;border-radius:10px;overflow:hidden;transition:border-color 0.25s,transform 0.25s;position:relative}
  .bn-card:not(.bn-card--soon):hover{border-color:rgba(201,168,76,0.3);transform:translateY(-3px)}
  .bn-card--soon{cursor:default}
  .bn-card--teaser{opacity:0.55}

  /* ── Media ── */
  .bn-card__media{position:relative;aspect-ratio:4/3;overflow:hidden}
  .bn-card__media--teaser{aspect-ratio:16/9}
  .bn-card__img{width:100%;height:100%;background-size:cover;background-position:center;transition:transform 0.5s ease}
  .bn-card:not(.bn-card--soon):hover .bn-card__img{transform:scale(1.04)}

  /* placeholder — no image yet */
  .bn-card__media--placeholder{background:#0a0a0a;border-bottom:1px solid #111;display:flex;align-items:center;justify-content:center}
  .bn-card__media--placeholder::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 60%,rgba(201,168,76,0.03) 0%,transparent 70%);pointer-events:none}
  /* teaser image placeholders */
  .bn-card__img--urban{background:linear-gradient(145deg,#0a0c10,#0d0f14)}
  .bn-card__img--creator{background:linear-gradient(145deg,#0a0a0d,#0d0c14)}
  .bn-card__img--cinematic{background:linear-gradient(145deg,#0d0a0a,#140c0a)}

  .bn-card__overlay{position:absolute;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.25s;z-index:2}
  .bn-card:not(.bn-card--soon):hover .bn-card__overlay{opacity:1}
  .bn-card__cta{font-size:0.72rem;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;color:#0a0a0a;background:#c9a84c;padding:0.65rem 1.4rem;border-radius:3px}

  .bn-card__badge{position:absolute;top:1rem;left:1rem;font-size:0.55rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#0a0a0a;background:#c9a84c;padding:0.28rem 0.65rem;border-radius:2px;z-index:2}
  .bn-card__badge--soon{background:transparent;color:#2a2a2a;border:1px solid #1e1e1e}
  .bn-card__badge--complete{background:#fff;color:#0a0a0a}
  .bn-card__count{position:absolute;top:1rem;right:1rem;font-size:0.58rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.35);z-index:2}
  .bn-card__count--soon{color:#1e1e1e}

  /* ── Body ── */
  .bn-card__body{padding:1.5rem;display:flex;flex-direction:column;height:100%}
  .bn-card__includes{flex:1}
  .bn-card__foot{margin-top:auto}
  .bn-card__collection{font-size:0.58rem;letter-spacing:0.2em;text-transform:uppercase;color:#c9a84c;font-weight:600;margin:0 0 0.35rem}
  .bn-card--teaser .bn-card__collection{color:#2a2a2a}
  .bn-card__name{font-size:1.1rem;font-weight:800;color:#fff;letter-spacing:-0.02em;margin:0 0 0.65rem;line-height:1.15}
  .bn-card--teaser .bn-card__name{color:#333}
  .bn-card__detail{font-size:0.76rem;color:#333;line-height:1.65;margin:0 0 1.1rem}
  .bn-card--teaser .bn-card__detail{color:#1e1e1e}

  .bn-card__includes{margin-bottom:1.1rem}
  .bn-card__inc-label{font-size:0.55rem;letter-spacing:0.18em;text-transform:uppercase;color:#1e1e1e;display:block;margin-bottom:0.5rem;font-weight:600}
  .bn-card__inc-tags{display:flex;flex-wrap:wrap;gap:0.35rem}
  .bn-card__inc-tags span{font-size:0.62rem;color:#2a2a2a;border:1px solid #161616;padding:0.2rem 0.55rem;border-radius:2px;letter-spacing:0.03em}
  .bn-card__inc-tags--muted span{color:#181818;border-color:#111}

  .bn-card__foot{display:flex;align-items:center;justify-content:space-between;gap:0.75rem;padding-top:1rem;border-top:1px solid #111;margin-top:auto}
  .bn-card__price-wrap{display:flex;flex-direction:column;gap:0.3rem}
  .bn-card__price{font-size:1.4rem;font-weight:900;color:#c9a84c;letter-spacing:-0.03em;line-height:1}
  .bn-card__price--tba{font-size:0.7rem;color:#222;letter-spacing:0.05em;font-weight:600;font-size:0.72rem}
  .bn-card__save{display:inline-block;font-size:0.55rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#0a0a0a;background:#c9a84c;padding:0.2rem 0.55rem;border-radius:2px;width:fit-content}
  .bn-card__save--muted{background:transparent;color:#1a1a1a;border:1px solid #141414}
  .bn-card__btn{display:inline-flex;align-items:center;font-size:0.65rem;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;color:#0a0a0a;background:#c9a84c;padding:0.65rem 1.1rem;border-radius:3px;white-space:nowrap;flex-shrink:0;transition:background 0.2s}
  .bn-card__btn--muted{background:transparent;color:#1a1a1a;border:1px solid #141414}

  /* ── Divider ── */
  .bn-divider{display:flex;align-items:center;gap:1.5rem;max-width:1100px;margin:0 auto 4rem;padding:0 2rem;position:relative;z-index:1}
  .bn-divider__line{flex:1;height:1px;background:#111}
  .bn-divider__label{font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:#1e1e1e;white-space:nowrap;flex-shrink:0}

  /* ── Notify strip ── */
  .bn-notify{background:#0d0d0d;border:1px solid #1a1a1a;border-radius:10px;padding:2.5rem;margin:2.5rem 0 5rem}
  .bn-notify__inner{display:flex;align-items:center;justify-content:space-between;gap:2rem;flex-wrap:wrap}
  .bn-notify__title{font-size:0.95rem;font-weight:700;color:#fff;margin:0 0 0.3rem}
  .bn-notify__sub{font-size:0.78rem;color:#333;margin:0}
  .bn-notify__form{display:flex;gap:0.75rem}
  .bn-notify__input{background:#0a0a0a;border:1px solid #1e1e1e;border-radius:3px;padding:0.8rem 1.1rem;font-size:0.85rem;color:#fff;font-family:inherit;outline:none;transition:border-color 0.2s;min-width:220px}
  .bn-notify__input::placeholder{color:#222}
  .bn-notify__input:focus{border-color:rgba(201,168,76,0.4)}
  .bn-notify__btn{background:#c9a84c;color:#0a0a0a;border:none;border-radius:3px;padding:0.8rem 1.4rem;font-size:0.78rem;font-weight:800;letter-spacing:0.08em;text-transform:uppercase;font-family:inherit;cursor:pointer;transition:background 0.2s;white-space:nowrap}
  .bn-notify__btn:hover{background:#d9b85c}
  .bn-notify__thanks{font-size:0.85rem;color:#c9a84c;margin:0}

  /* ── Why Bundle ── */
  .bn-why{background:#080808;border-top:1px solid #111;padding:5rem 2rem 6rem;position:relative;z-index:1}
  .bn-why__inner{max-width:1100px;margin:0 auto;text-align:center}
  .bn-why__inner .bn-eyebrow{margin-bottom:3rem}
  .bn-why__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;text-align:left}
  .bn-why__item{background:#0d0d0d;border:1px solid #141414;border-radius:8px;padding:1.75rem;display:flex;flex-direction:column;gap:0.75rem}
