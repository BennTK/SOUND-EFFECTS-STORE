<!-- Spectra Sound — Product Page -->
<div class="pd-wrap">

  <div class="pd-glow"></div>

  <!-- Breadcrumb -->
  <div class="pd-breadcrumb">
    <a href="/collections/sound-effects">Sound Effects</a>
    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
    <span>{{ product.title }}</span>
  </div>

  <!-- Main Layout -->
  <div class="pd-main">

    <!-- Left: Image -->
    <div class="pd-media">
      <div class="pd-media__img-wrap">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title }}" class="pd-media__img">
        {% else %}
          <div class="pd-media__placeholder">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(201,168,76,0.2)" stroke-width="1"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
          </div>
        {% endif %}
      </div>
    </div>

    <!-- Right: Info -->
    <div class="pd-info">

      <div>
        <p class="pd-info__collection">Drone Fly Bys Collection</p>
        <h1 class="pd-info__title">{{ product.title }}</h1>
        {% if product.description != blank %}
          <p class="pd-info__desc">{{ product.description | strip_html | truncate: 220 }}</p>
        {% else %}
          <p class="pd-info__desc">Professionally recorded drone fly-by sound effects. Royalty-free, instant download, commercial license included.</p>
        {% endif %}
      </div>

      <!-- Meta -->
      <div class="pd-info__meta">
        <div class="pd-info__meta-item"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>High-quality WAV files</div>
        <div class="pd-info__meta-item"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Commercial license included</div>
        <div class="pd-info__meta-item"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Instant download</div>
        <div class="pd-info__meta-item"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Royalty-free forever</div>
      </div>

      <!-- Buy -->
      <div class="pd-purchase">
        {% form 'product', product %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <div class="pd-purchase__price-row">
            <span class="pd-purchase__price">{{ product.price | money }}</span>
            {% if product.compare_at_price > product.price %}
              <span class="pd-purchase__compare">{{ product.compare_at_price | money }}</span>
              <span class="pd-purchase__save">Save {{ product.compare_at_price | minus: product.price | money }}</span>
            {% endif %}
          </div>
          {% if product.variants.size > 1 %}
            <div class="pd-purchase__variants">
              {% for variant in product.variants %}
                <label class="pd-purchase__variant {% if variant == product.selected_or_first_available_variant %}pd-purchase__variant--active{% endif %}">
                  <input type="radio" name="id" value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}checked{% endif %} style="display:none">
                  {{ variant.title }}
                </label>
              {% endfor %}
            </div>
          {% endif %}
          <button type="submit" name="add" class="pd-purchase__btn" {% unless product.available %}disabled{% endunless %}>
            {% if product.available %}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
              Add to Cart — {{ product.price | money }}
            {% else %}
              Sold Out
            {% endif %}
          </button>
          <p class="pd-purchase__note"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>Secure checkout · Instant delivery to your email</p>
        {% endform %}
      </div>

      <!-- License -->
      <div class="pd-license">
        <div class="pd-license__icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 12l2 2 4-4"/></svg></div>
        <div>
          <p class="pd-license__title">Individual License — auto-granted on purchase</p>
          <p class="pd-license__desc">Use in any personal or commercial project. No attribution required. <a href="/pages/licensing">Full terms →</a></p>
        </div>
      </div>

    </div>
  </div>

  <!-- Description -->
  {% if product.description != blank %}
  <div class="pd-desc-section">
    <div class="pd-desc-section__inner">
      <p class="pd-label">About this pack</p>
      <div class="pd-desc-content">{{ product.description }}</div>
    </div>
  </div>
  {% endif %}

  <!-- Related Packs -->
  <div class="pd-related">
    <div class="pd-related__inner">
      <p class="pd-label">More Packs</p>
      <h2 class="pd-related__title">Drone Fly Bys Collection</h2>
      <div class="pd-related__grid">
        {%- assign all_packs = "Forest & Trees,drone-fly-bys-forest,forest|Rocks & Cliffs,drone-fly-bys-rocks-cliffs,rocks|Ocean & Waves,drone-fly-bys-ocean-waves,ocean|Wind,drone-fly-bys-wind,wind|Waterfalls,drone-fly-bys-waterfalls,water|Rivers & Lakes,drone-fly-bys-rivers-lakes,rivers|Insects,drone-fly-bys-insects,insects|Grass & Fields,drone-fly-bys-grass-fields,grass" | split: "|" -%}
        {%- for pack in all_packs -%}
          {%- assign parts = pack | split: "," -%}
          {%- if parts[1] != product.handle -%}
            <a href="/products/{{ parts[1] }}" class="pd-related__card">
              <div class="pd-related__img pd-related__img--{{ parts[2] }}"></div>
              <div class="pd-related__info">
                <p>{{ parts[0] }}</p>
                <span>→</span>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div style="text-align:center;margin-top:2rem">
        <a href="/collections/sound-effects" class="pd-related__all">View all packs →</a>
      </div>
    </div>
  </div>

</div>

<style>
  .pd-wrap { background:#0a0a0a; min-height:100vh; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; position:relative; overflow-x:hidden; }
  .pd-glow { position:absolute; top:-60px; left:50%; transform:translateX(-50%); width:900px; height:500px; background:radial-gradient(ellipse,rgba(201,168,76,0.05) 0%,transparent 65%); pointer-events:none; z-index:0; }

  .pd-breadcrumb { max-width:1100px; margin:0 auto; padding:2rem 2rem 0; display:flex; align-items:center; gap:0.5rem; font-size:0.7rem; color:#333; position:relative; z-index:1; }
  .pd-breadcrumb a { color:#333; text-decoration:none; transition:color 0.2s; }
  .pd-breadcrumb a:hover { color:#c9a84c; }
  .pd-breadcrumb span { color:#555; }

  .pd-main { max-width:1100px; margin:0 auto; padding:2.5rem 2rem 5rem; display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:start; position:relative; z-index:1; }

  .pd-media__img-wrap { aspect-ratio:4/3; border-radius:10px; overflow:hidden; border:1px solid #1a1a1a; background:#0d0d0d; }
  .pd-media__img { width:100%; height:100%; object-fit:cover; display:block; }
  .pd-media__placeholder { width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:linear-gradient(145deg,#0d0d0d,#111); }

  .pd-info { display:flex; flex-direction:column; gap:1.75rem; }
  .pd-info__collection { font-size:0.6rem; letter-spacing:0.22em; text-transform:uppercase; color:#c9a84c; margin:0 0 0.5rem; font-weight:600; }
  .pd-info__title { font-size:clamp(1.75rem,3vw,2.5rem); font-weight:900; color:#fff; letter-spacing:-0.03em; margin:0 0 0.85rem; line-height:1.1; }
  .pd-info__desc { font-size:0.875rem; color:#3e3e3e; line-height:1.8; margin:0; }

  .pd-info__meta { display:flex; flex-direction:column; gap:0.55rem; padding:1.25rem; background:#0d0d0d; border:1px solid #161616; border-radius:6px; }
  .pd-info__meta-item { display:flex; align-items:center; gap:0.6rem; font-size:0.78rem; color:#444; }

  .pd-purchase { display:flex; flex-direction:column; gap:1rem; }
  .pd-purchase__price-row { display:flex; align-items:baseline; gap:0.75rem; }
  .pd-purchase__price { font-size:2.25rem; font-weight:900; color:#c9a84c; letter-spacing:-0.04em; line-height:1; }
  .pd-purchase__compare { font-size:1rem; color:#2e2e2e; text-decoration:line-through; }
  .pd-purchase__save { font-size:0.62rem; font-weight:700; color:#0a0a0a; background:#c9a84c; padding:0.18rem 0.5rem; border-radius:2px; letter-spacing:0.08em; text-transform:uppercase; }
  .pd-purchase__variants { display:flex; gap:0.5rem; flex-wrap:wrap; }
  .pd-purchase__variant { font-size:0.75rem; color:#555; border:1px solid #1e1e1e; padding:0.45rem 1rem; border-radius:3px; cursor:pointer; transition:all 0.2s; }
  .pd-purchase__variant--active { border-color:#c9a84c; color:#c9a84c; }
  .pd-purchase__btn { display:flex; align-items:center; justify-content:center; gap:0.65rem; width:100%; background:#c9a84c; color:#0a0a0a; font-size:0.85rem; font-weight:800; letter-spacing:0.1em; text-transform:uppercase; border:none; padding:1.1rem 2rem; border-radius:5px; cursor:pointer; transition:background 0.2s,transform 0.15s; }
  .pd-purchase__btn:hover { background:#d9b85c; transform:translateY(-1px); }
  .pd-purchase__btn:disabled { background:#1a1a1a; color:#333; cursor:not-allowed; transform:none; }
  .pd-purchase__note { display:flex; align-items:center; justify-content:center; gap:0.45rem; font-size:0.68rem; color:#2a2a2a; margin:0; }

  .pd-license { display:flex; align-items:flex-start; gap:0.85rem; padding:1rem 1.25rem; background:rgba(201,168,76,0.04); border:1px solid rgba(201,168,76,0.1); border-radius:6px; }
  .pd-license__icon { width:28px; height:28px; border-radius:4px; background:rgba(201,168,76,0.08); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .pd-license__title { font-size:0.73rem; font-weight:600; color:#888; margin:0 0 0.2rem; }
  .pd-license__desc { font-size:0.68rem; color:#333; margin:0; line-height:1.5; }
  .pd-license__desc a { color:#c9a84c; text-decoration:none; border-bottom:1px solid rgba(201,168,76,0.25); }

  .pd-label { font-size:0.6rem; letter-spacing:0.22em; text-transform:uppercase; color:#c9a84c; margin:0 0 1.25rem; font-weight:600; }

  .pd-desc-section { border-top:1px solid #111; padding:4rem 2rem; position:relative; z-index:1; }
  .pd-desc-section__inner { max-width:1100px; margin:0 auto; }
  .pd-desc-content { font-size:0.9rem; color:#444; line-height:1.85; max-width:680px; }

  .pd-related { background:#080808; border-top:1px solid #111; padding:5rem 2rem 6rem; position:relative; z-index:1; }
  .pd-related__inner { max-width:1100px; margin:0 auto; }
  .pd-related__title { font-size:clamp(1.4rem,2.5vw,1.8rem); font-weight:800; color:#fff; letter-spacing:-0.02em; margin:0 0 2rem; }
  .pd-related__grid { display:grid; grid-template-columns:repeat(4,1fr); gap:0.75rem; }
  .pd-related__card { text-decoration:none; background:#0d0d0d; border:1px solid #161616; border-radius:6px; overflow:hidden; transition:border-color 0.2s,transform 0.2s; }
  .pd-related__card:hover { border-color:rgba(201,168,76,0.2); transform:translateY(-2px); }
  .pd-related__img { aspect-ratio:16/9; background-size:cover; background-position:center; }
  .pd-related__img--forest { background:linear-gradient(145deg,#0a1a0a,#081508); }
  .pd-related__img--rocks { background:url('{{ "rocks-cliffs-cover.jpg" | asset_url }}') center/cover no-repeat; }
  .pd-related__img--ocean { background:url('{{ "drone-ocean.jpg" | asset_url }}') center/cover no-repeat; }
  .pd-related__img--forest { background:url('{{ "forest-trees-cover.jpg" | asset_url }}') center/cover no-repeat; }
  .pd-related__img--water { background:linear-gradient(145deg,#080e18,#060c16); }
  .pd-related__img--wind { background:linear-gradient(145deg,#0c0e14,#080a10); }
  .pd-related__img--rivers { background:linear-gradient(145deg,#060e18,#040c14); }
  .pd-related__img--insects { background:linear-gradient(145deg,#0e1208,#0a0e06); }
  .pd-related__img--grass { background:linear-gradient(145deg,#081408,#061006); }
  .pd-related__info { display:flex; justify-content:space-between; align-items:center; padding:0.6rem 0.75rem; }
  .pd-related__info p { font-size:0.68rem; font-weight:600; color:#555; margin:0; }
  .pd-related__info span { font-size:0.68rem; color:#2a2a2a; }
  .pd-related__card:hover .pd-related__info p,
  .pd-related__card:hover .pd-related__info span { color:#c9a84c; }
  .pd-related__all { font-size:0.75rem; color:#333; text-decoration:none; border-bottom:1px solid #1e1e1e; padding-bottom:2px; transition:color 0.2s,border-color 0.2s; }
  .pd-related__all:hover { color:#c9a84c; border-color:#c9a84c; }

  @media (max-width:860px) { .pd-main { grid-template-columns:1fr; gap:2.5rem; } .pd-related__grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:540px) { .pd-main { padding:1.5rem 1.25rem 4rem; } .pd-desc-section { padding:3rem 1.25rem; } .pd-related { padding:3rem 1.25rem 4rem; } }
</style>
