{%- comment -%}
Footer Section
{%- endcomment -%}

<footer class="footer">
  <div class="footer-container">
    <!-- Footer Column 1: About -->
    <div class="footer-column">
      <h4>About</h4>
      <ul class="footer-links">
        <li><a href="/pages/about">About Us</a></li>
        <li><a href="/pages/blog">Blog</a></li>
        <li><a href="/pages/careers">Careers</a></li>
        <li><a href="/pages/press">Press</a></li>
      </ul>
    </div>
    
    <!-- Footer Column 2: Products -->
    <div class="footer-column">
      <h4>Products</h4>
      <ul class="footer-links">
        <li><a href="/collections/all">All Sounds</a></li>
        <li><a href="/collections">Collections</a></li>
        <li><a href="/pages/licensing">Licensing</a></li>
        <li><a href="/pages/faq">FAQ</a></li>
      </ul>
    </div>
    
    <!-- Footer Column 3: Support -->
    <div class="footer-column">
      <h4>Support</h4>
      <ul class="footer-links">
        <li><a href="mailto:support@soundeffects.com">Contact Support</a></li>
        <li><a href="/pages/downloads">Downloads</a></li>
        <li><a href="/pages/troubleshooting">Troubleshooting</a></li>
        <li><a href="/pages/refund-policy">Refund Policy</a></li>
      </ul>
    </div>
    
    <!-- Footer Column 4: Legal -->
    <div class="footer-column">
      <h4>Legal</h4>
      <ul class="footer-links">
        <li><a href="/pages/privacy">Privacy Policy</a></li>
        <li><a href="/pages/terms">Terms of Service</a></li>
        <li><a href="/pages/contact">Contact</a></li>
      </ul>
    </div>
  </div>
  
  <!-- Footer Bottom -->
  <div class="footer-bottom">
    <div class="footer-bottom-container">
      <p class="copyright">&copy; 2026 {{ shop.name }}. All rights reserved.</p>
      
      <!-- Social Media -->
      <div class="social-links">
        <a href="//twitter.com" target="_blank" class="social-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.5c4.75 2.25 7-7 7-7"></path>
          </svg>
        </a>
        <a href="//instagram.com" target="_blank" class="social-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path>
            <circle cx="17.5" cy="6.5" r="1.5"></circle>
          </svg>
        </a>
        <a href="//youtube.com" target="_blank" class="social-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    background-color: #1a1a1a;
    color: #ccc;
    padding-top: 3rem;
  }
  
  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem 2rem 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }
  
  .footer-column h4 {
    color: #fff;
    font-size: 1rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  
  .footer-links li {
    margin-bottom: 0.75rem;
  }
  
  .footer-links a {
    color: #999;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .footer-links a:hover {
    color: #e74c3c;
  }
  
  .footer-bottom {
    background-color: #0d0d0d;
    padding: 1.5rem 2rem;
  }
  
  .footer-bottom-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .copyright {
    margin: 0;
    font-size: 0.85rem;
    color: #666;
  }
  
  .social-links {
    display: flex;
    gap: 1.5rem;
  }
  
  .social-icon {
    color: #666;
    transition: color 0.3s ease;
  }
  
  .social-icon:hover {
    color: #e74c3c;
  }
  
  @media (max-width: 768px) {
    .footer-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
      padding: 0 1.5rem 1.5rem 1.5rem;
    }
    
    .footer-bottom-container {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
{% endstylesheet %}
