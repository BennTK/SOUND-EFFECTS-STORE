<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }}</title>
  <link rel="stylesheet" href="{{ 'styles.css' | asset_url }}">
  {% block head %}{% endblock %}
</head>
<body>
  <!-- Header / Navigation -->
  {% section 'header' %}
  
  <!-- Main Content -->
  <main id="main-content">
    {{ content_for_layout }}
  </main>
  
  <!-- Footer -->
  {% section 'footer' %}
  
  <script src="{{ 'script.js' | asset_url }}"></script>
</body>
</html>
