<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Spectra Sound — Coming Soon</title>
  {{ content_for_header }}
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0a0a0a;
      color: #fff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow-x: hidden;
      position: relative;
    }

    /* ── Ambient glow ── */
    body::before {
      content: '';
      position: fixed;
      top: -200px;
      left: 50%;
      transform: translateX(-50%);
      width: 900px;
      height: 600px;
      background: radial-gradient(ellipse, rgba(201,168,76,0.10) 0%, transparent 65%);
      pointer-events: none;
      z-index: 0;
    }

    body::after {
      content: '';
      position: fixed;
      bottom: -100px;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 400px;
      background: radial-gradient(ellipse, rgba(201,168,76,0.04) 0%, transparent 65%);
      pointer-events: none;
      z-index: 0;
    }

    /* ── Main container ── */
    .cs-wrap {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 640px;
      padding: 3rem 2rem 4rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0;
    }

    /* ── Logo / wordmark ── */
    .cs-logo {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 3.5rem;
    }

    .cs-logo__icon {
      width: 32px;
      height: 32px;
      border: 1.5px solid rgba(201,168,76,0.5);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .cs-logo__icon svg { display: block; }

    .cs-logo__text {
      font-size: 1rem;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #fff;
    }

    /* ── Badge ── */
    .cs-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(201,168,76,0.08);
      border: 1px solid rgba(201,168,76,0.2);
      border-radius: 100px;
      padding: 0.35rem 1rem;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #c9a84c;
      margin-bottom: 1.75rem;
    }

    .cs-badge__dot {
      width: 5px;
      height: 5px;
      background: #c9a84c;
      border-radius: 50%;
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.7); }
    }

    /* ── Headline ── */
    .cs-headline {
      font-size: clamp(3rem, 10vw, 5.5rem);
      font-weight: 900;
      line-height: 0.95;
      letter-spacing: -0.04em;
      color: #fff;
      margin-bottom: 1.75rem;
    }

    .cs-headline span {
      display: block;
      background: linear-gradient(135deg, #c9a84c 0%, #e8cc7a 50%, #c9a84c 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Sub copy ── */
    .cs-sub {
      font-size: 0.95rem;
      color: #555;
      line-height: 1.75;
      max-width: 440px;
      margin-bottom: 3rem;
    }

    /* ── Divider ── */
    .cs-divider {
      width: 40px;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(201,168,76,0.4), transparent);
      margin-bottom: 2.5rem;
    }

    /* ── Email section ── */
    .cs-email-section {
      width: 100%;
      margin-bottom: 2.5rem;
    }

    .cs-email-label {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #c9a84c;
      margin-bottom: 1.25rem;
    }

    /* ── MailerLite embed slot ── */
    /* Replace the placeholder below with your MailerLite embed code */
    .cs-mailerlite-wrap {
      width: 100%;
    }

    /* Override MailerLite form styles to match dark theme */
    .cs-mailerlite-wrap .ml-embedded,
    .cs-mailerlite-wrap form {
      background: transparent !important;
    }

    /* Fallback native form (shown if MailerLite embed not yet added) */
    .cs-native-form {
      display: flex;
      gap: 0.6rem;
      width: 100%;
    }

    .cs-native-form input[type="email"] {
      flex: 1;
      background: #0e0e0e;
      border: 1px solid #1e1e1e;
      border-radius: 6px;
      padding: 0.9rem 1.25rem;
      color: #fff;
      font-family: inherit;
      font-size: 0.88rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .cs-native-form input[type="email"]::placeholder { color: #333; }
    .cs-native-form input[type="email"]:focus { border-color: rgba(201,168,76,0.4); }

    .cs-native-form button {
      background: #c9a84c;
      color: #0a0a0a;
      border: none;
      border-radius: 6px;
      padding: 0.9rem 1.5rem;
      font-family: inherit;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.2s, transform 0.15s;
    }

    .cs-native-form button:hover {
      background: #d9b85c;
      transform: translateY(-1px);
    }

    /* ── Trust line ── */
    .cs-trust {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      flex-wrap: wrap;
      margin-bottom: 4rem;
    }

    .cs-trust__item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.65rem;
      color: #2e2e2e;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .cs-trust__item svg { opacity: 0.4; }

    /* ── Password access (for store owner) ── */
    .cs-access {
      width: 100%;
      border-top: 1px solid #111;
      padding-top: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }

    .cs-access__label {
      font-size: 0.6rem;
      color: #252525;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .cs-access__form {
      display: flex;
      gap: 0.5rem;
      width: 100%;
      max-width: 340px;
    }

    .cs-access__form input[type="password"] {
      flex: 1;
      background: #0d0d0d;
      border: 1px solid #161616;
      border-radius: 5px;
      padding: 0.65rem 1rem;
      color: #555;
      font-family: inherit;
      font-size: 0.8rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .cs-access__form input[type="password"]:focus { border-color: #2a2a2a; }
    .cs-access__form input[type="password"]::placeholder { color: #222; }

    .cs-access__form button {
      background: #111;
      color: #333;
      border: 1px solid #1a1a1a;
      border-radius: 5px;
      padding: 0.65rem 1.1rem;
      font-family: inherit;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s;
    }

    .cs-access__form button:hover { border-color: #2a2a2a; color: #555; }

    .cs-access__err {
      font-size: 0.72rem;
      color: rgba(201,168,76,0.6);
    }

    @media (max-width: 520px) {
      .cs-native-form { flex-direction: column; }
      .cs-trust { gap: 1rem; }
      .cs-access__form { flex-direction: column; }
    }
  </style>
</head>
<body>

  <div class="cs-wrap">

    <!-- Logo -->
    <div class="cs-logo">
      <div class="cs-logo__icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18V5l12-2v13"/>
          <circle cx="6" cy="18" r="3"/>
          <circle cx="18" cy="16" r="3"/>
        </svg>
      </div>
      <span class="cs-logo__text">Spectra Sound</span>
    </div>

    <!-- Badge -->
    <div class="cs-badge">
      <span class="cs-badge__dot"></span>
      Coming Soon
    </div>

    <!-- Headline -->
    <h1 class="cs-headline">
      Sound Effects<br>
      <span>Redefined.</span>
    </h1>

    <!-- Sub copy -->
    <p class="cs-sub">
      Premium drone fly-by sound effects for creators who demand the best.
      Cinematic-grade audio, instant download, royalty-free forever.
      Launching soon — be first to know.
    </p>

    <div class="cs-divider"></div>

    <!-- Email signup -->
    <div class="cs-email-section">
      <p class="cs-email-label">Get early access &amp; launch discount</p>

      <div class="cs-mailerlite-wrap">
        <!-- ═══════════════════════════════════════════════════
             PASTE YOUR MAILERLITE EMBED CODE HERE
             (replace the cs-native-form block below)
             To get it: MailerLite dashboard → Forms → Embedded
             → Copy embed code → paste in place of the form below
        ════════════════════════════════════════════════════ -->

        <!-- FALLBACK FORM — remove once MailerLite embed is added -->
        <form class="cs-native-form" action="#" method="post">
          <input type="email" name="email" placeholder="Your email address" required>
          <button type="submit">Notify Me</button>
        </form>

      </div>
    </div>

    <!-- Trust -->
    <div class="cs-trust">
      <div class="cs-trust__item">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Royalty-Free
      </div>
      <div class="cs-trust__item">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        WAV Quality
      </div>
      <div class="cs-trust__item">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Instant Download
      </div>
      <div class="cs-trust__item">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        Commercial License
      </div>
    </div>

    <!-- Store owner password access -->
    <div class="cs-access">
      <p class="cs-access__label">Store access</p>
      {% form 'storefront_password' %}
        <div class="cs-access__form">
          <input type="password" name="password" placeholder="Enter store password">
          <button type="submit">Enter</button>
        </div>
        {% if form.errors %}
          <p class="cs-access__err">Incorrect password — try again</p>
        {% endif %}
      {% endform %}
    </div>

  </div>

  <!-- Required by Shopify — hidden since custom form above handles access -->
  <div style="display:none">{{ content_for_layout }}</div>

</body>
</html>
