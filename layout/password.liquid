<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Spectra Sound — Coming Soon</title>
  {{ content_for_header }}
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #c9a84c;
      --gold-light: #e8cc7a;
      --bg: #0a0a0a;
      --surface: #0e0e0e;
      --border: #1a1a1a;
      --text-muted: #444;
    }

    body {
      background: var(--bg);
      color: #fff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow-x: hidden;
      position: relative;
    }

    .glow-top {
      position: fixed;
      top: -180px;
      left: 50%;
      transform: translateX(-50%);
      width: 1000px;
      height: 600px;
      background: radial-gradient(ellipse, rgba(201,168,76,0.10) 0%, transparent 65%);
      pointer-events: none;
      z-index: 0;
    }
    .glow-bottom {
      position: fixed;
      bottom: -120px;
      left: 50%;
      transform: translateX(-50%);
      width: 700px;
      height: 400px;
      background: radial-gradient(ellipse, rgba(201,168,76,0.04) 0%, transparent 65%);
      pointer-events: none;
      z-index: 0;
    }

    .wrap {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 620px;
      padding: 3rem 2rem 4rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    /* ── Logo ── */
    .logo {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      margin-bottom: 3.5rem;
    }
    .logo__icon {
      width: 34px;
      height: 34px;
      border: 1.5px solid rgba(201,168,76,0.45);
      border-radius: 7px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(201,168,76,0.04);
    }
    .logo__text {
      font-size: 1rem;
      font-weight: 800;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #fff;
    }

    /* ── Badge ── */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(201,168,76,0.07);
      border: 1px solid rgba(201,168,76,0.2);
      border-radius: 100px;
      padding: 0.38rem 1.1rem;
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.75rem;
    }
    .badge__dot {
      width: 5px;
      height: 5px;
      background: var(--gold);
      border-radius: 50%;
      animation: pulse 2.2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%,100% { opacity:1; transform:scale(1); }
      50%      { opacity:0.3; transform:scale(0.65); }
    }

    /* ── Headline ── */
    .headline {
      font-size: clamp(3rem, 11vw, 5.5rem);
      font-weight: 900;
      line-height: 0.92;
      letter-spacing: -0.04em;
      color: #fff;
      margin-bottom: 1.75rem;
    }
    .headline span {
      display: block;
      background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 45%, var(--gold) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Sub ── */
    .sub {
      font-size: 0.96rem;
      color: var(--text-muted);
      line-height: 1.8;
      max-width: 430px;
      margin-bottom: 2.75rem;
    }

    .divider {
      width: 40px;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(201,168,76,0.4), transparent);
      margin-bottom: 2.5rem;
    }

    /* ── Email section ── */
    .email-section { width: 100%; margin-bottom: 2.5rem; }

    .email-label {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.1rem;
    }

    .email-form {
      display: flex;
      gap: 0.6rem;
      width: 100%;
    }
    .email-form input[type="email"] {
      flex: 1;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 7px;
      padding: 0.95rem 1.25rem;
      color: #fff;
      font-family: inherit;
      font-size: 0.88rem;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      min-width: 0;
    }
    .email-form input[type="email"]::placeholder { color: #2c2c2c; }
    .email-form input[type="email"]:focus {
      border-color: rgba(201,168,76,0.45);
      box-shadow: 0 0 0 3px rgba(201,168,76,0.06);
    }
    .email-form button {
      background: var(--gold);
      color: #0a0a0a;
      border: none;
      border-radius: 7px;
      padding: 0.95rem 1.6rem;
      font-family: inherit;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.2s, transform 0.15s;
      flex-shrink: 0;
    }
    .email-form button:hover { background: var(--gold-light); transform: translateY(-1px); }
    .email-form button:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    .form-msg { min-height: 1.1rem; font-size: 0.75rem; margin-top: 0.65rem; }
    .form-msg--error   { color: #b05050; }
    .form-msg--success { color: var(--gold); }

    /* ── Success card ── */
    .success-card {
      display: none;
      flex-direction: column;
      align-items: center;
      gap: 0.85rem;
      padding: 2rem 1.5rem;
      background: rgba(201,168,76,0.05);
      border: 1px solid rgba(201,168,76,0.18);
      border-radius: 12px;
      width: 100%;
      animation: fadeIn 0.4s ease;
    }
    .success-card.show { display: flex; }
    @keyframes fadeIn { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:none; } }
    .success-card__icon {
      width: 48px; height: 48px;
      background: rgba(201,168,76,0.1);
      border: 1px solid rgba(201,168,76,0.25);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
    }
    .success-card__title { font-size: 1rem; font-weight: 800; color: #fff; }
    .success-card__sub { font-size: 0.78rem; color: var(--text-muted); line-height: 1.7; max-width: 360px; }

    /* ── Trust ── */
    .trust {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      flex-wrap: wrap;
      margin-bottom: 4rem;
    }
    .trust__item {
      display: flex; align-items: center; gap: 0.4rem;
      font-size: 0.62rem; color: #282828;
      letter-spacing: 0.1em; text-transform: uppercase;
    }
    .trust__item svg { opacity: 0.35; }

    /* ── Store owner access ── */
    .access {
      width: 100%;
      border-top: 1px solid #111;
      padding-top: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.85rem;
    }
    .access__label { font-size: 0.58rem; color: #222; letter-spacing: 0.15em; text-transform: uppercase; }
    .access__form { display: flex; gap: 0.5rem; width: 100%; max-width: 340px; }
    .access__form input[type="password"] {
      flex: 1;
      background: #0d0d0d; border: 1px solid #161616; border-radius: 5px;
      padding: 0.65rem 1rem; color: #555; font-family: inherit; font-size: 0.8rem;
      outline: none; transition: border-color 0.2s;
    }
    .access__form input[type="password"]:focus { border-color: #2a2a2a; }
    .access__form input[type="password"]::placeholder { color: #222; }
    .access__form button {
      background: #111; color: #333; border: 1px solid #1a1a1a; border-radius: 5px;
      padding: 0.65rem 1.1rem; font-family: inherit; font-size: 0.72rem; font-weight: 700;
      letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer;
      transition: border-color 0.2s, color 0.2s;
    }
    .access__form button:hover { border-color: #2a2a2a; color: #555; }
    .access__err { font-size: 0.72rem; color: rgba(201,168,76,0.6); }

    @media (max-width: 500px) {
      .email-form { flex-direction: column; }
      .trust { gap: 1rem; }
      .access__form { flex-direction: column; }
    }
  </style>
</head>
<body>

  <div class="glow-top"></div>
  <div class="glow-bottom"></div>

  <div class="wrap">

    <div class="logo">
      <div class="logo__icon">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
        </svg>
      </div>
      <span class="logo__text">Spectra Sound</span>
    </div>

    <div class="badge"><span class="badge__dot"></span>Coming Soon</div>

    <h1 class="headline">Sound Effects<br><span>Redefined.</span></h1>

    <p class="sub">Premium drone fly-by sound effects for creators who demand the best. Cinematic-grade WAV audio, instant download, royalty-free forever. Launching soon — be the first to know.</p>

    <div class="divider"></div>

    <div class="email-section" id="email-section">
      <p class="email-label">Get early access &amp; a launch discount</p>

      <form class="email-form" id="signup-form" novalidate>
        <input type="email" id="email-input" placeholder="Your email address" autocomplete="email" required>
        <button type="submit" id="submit-btn">Notify Me</button>
      </form>
      <p class="form-msg" id="form-msg" aria-live="polite"></p>

      <div class="success-card" id="success-card">
        <div class="success-card__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <p class="success-card__title">You're on the list.</p>
        <p class="success-card__sub">We'll notify you the moment Spectra Sound launches — along with an exclusive early-access discount.</p>
      </div>
    </div>

    <div class="trust">
      <div class="trust__item"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Royalty-Free</div>
      <div class="trust__item"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>WAV Quality</div>
      <div class="trust__item"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Instant Download</div>
      <div class="trust__item"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Commercial License</div>
    </div>

    <div class="access">
      <p class="access__label">Store access</p>
      {% form 'storefront_password' %}
        <div class="access__form">
          <input type="password" name="password" placeholder="Enter store password">
          <button type="submit">Enter</button>
        </div>
        {% if form.errors %}
          <p class="access__err">Incorrect password — try again</p>
        {% endif %}
      {% endform %}
    </div>

  </div>

  <div style="display:none">{{ content_for_layout }}</div>

  <script>
  (function () {
    var ML_TOKEN = 'eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9.eyJhdWQiOiI0IiwianRpIjoiZmFhNzZkZWU1M2Q1NzBiNDMyOGYwZDlmNDZlYWQ5OWJkNmFhOTdlMzRlZTAyYjVjNTQ1OTVjMDg0OWVmNWM4YjMyMzQ4N2MwODI3M2M5OTIiLCJpYXQiOjE3ODA5NzYzMjUuMzI5NjEyLCJuYmYiOjE3ODA5NzYzMjUuMzI5NjE0LCJleHAiOjQ5MzY2NDk5MjUuMzI1MzYyLCJzdWIiOiIyNDM2NzI1Iiwic2NvcGVzIjpbXX0.xJcGScU4TPzhrmMB2l4VGViQHx5egwusWqGoNAUSIjb7joNCz22JI9wozHOMeAO7LT6ZxlP-30YLTKXQw2XXTT2t2Ev8Tgim2mv88Uur0hjPJug01A7Z9J0w0jfRh_vEXX-Tp8WQyJA7l9xmvsUiBHD7ja3DLJ1yHTjpM6nVBH43EVucqjZBfAFu0Y1jLMcr_AAETl6c73dPOnjLTUS8mPH4AKg-lstuGwE9BbORdoGtg4mDck0DFGzDZwv3CSx6RbC6FYljA_y7bLZBolKYcF09q44BvQVRlCdW73-CfTfO6PcBHljZs4WY9sSsSt0YY7Ma13xg6hz4Gq9sf3eSMYpzi7nGPsrmTLsExkHzU64JVrkL6MaIDbx40JlW25S1cO-5Pe84FdLySeMPmOIsXAe6HM7h32GlwIt8lYztT2h514Vuf78IWlBN4eZnXdk__N-fJG6Yg9h4vglTC1ezb4Sb_y0r4wFdtMVA7CrXMnT0wUoXwBdMIz08qzHwqpcGAcO1g08_gvHeTMkpWz0yX0EJDxWsasrBrhPPz6bz_f-hxGeR9bLo0OrOmK0tp7Zcbh2QQoYM78GxC0fAMTELoLWgpoEQ-91yNJ3vVDIn4tn9azg6CQj8YvgUNtVxvyjFS3g-COLHUcmQXO-Foh4MLmr9oH1UmoeYwcuTCjDQ_vo';
    var ML_GROUP = '189766928641820360';

    var form        = document.getElementById('signup-form');
    var input       = document.getElementById('email-input');
    var btn         = document.getElementById('submit-btn');
    var msg         = document.getElementById('form-msg');
    var successCard = document.getElementById('success-card');

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var email = input.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        msg.textContent = 'Please enter a valid email address.';
        msg.className = 'form-msg form-msg--error';
        return;
      }
      btn.disabled = true;
      btn.textContent = 'Sending…';
      msg.textContent = '';

      fetch('https://connect.mailerlite.com/api/subscribers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + ML_TOKEN },
        body: JSON.stringify({ email: email, groups: [ML_GROUP] })
      })
      .then(function (res) {
        if (res.status === 200 || res.status === 201 || res.status === 409) {
          form.style.display = 'none';
          msg.textContent = '';
          successCard.classList.add('show');
        } else { throw new Error(); }
      })
      .catch(function () {
        btn.disabled = false;
        btn.textContent = 'Notify Me';
        msg.textContent = 'Something went wrong — please try again.';
        msg.className = 'form-msg form-msg--error';
      });
    });
  })();
  </script>

</body>
</html>
