{% stylesheet %}
  .ss-testimonials-section {
    background: #0a0a0a;
    padding: 3rem 0 2.5rem;
    border-top: 1px solid #161616;
  }

  .ss-testimonials-section .ss-proof__container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .ss-testimonials-section .ss-proof__headline {
    text-align: center;
    margin-bottom: 2rem;
  }

  .ss-testimonials-section .ss-proof__number {
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 900;
    color: #fff;
    margin: 0 0 0.5rem;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .ss-testimonials-section .ss-proof__tagline {
    color: #555;
    margin: 0 0 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
  }

  .ss-testimonials-section .ss-proof__stars {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: #c9a84c;
    font-size: 1.4rem;
  }

  .ss-testimonials-section .ss-proof__rating-text {
    font-size: 0.8rem;
    color: #555;
    letter-spacing: 0.05em;
  }

  .ss-carousel-outer {
    width: 100%;
    padding: 0 2rem 1rem;
    box-sizing: border-box;
  }

  .ss-carousel-viewport {
    width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .ss-carousel-viewport::-webkit-scrollbar { display: none; }

  .ss-carousel-track {
    display: flex;
    flex-direction: row;
    gap: 0;
    width: 100%;
  }

  .ss-tcard {
    flex: 1 1 0;
    min-width: 0;
    background: #0e0e0e;
    border: 1px solid #1e1e1e;
    border-right: none;
    display: flex;
    flex-direction: column;
    transition: background 0.2s;
  }

  .ss-tcard:first-child { border-radius: 10px 0 0 10px; }
  .ss-tcard:last-child  { border-right: 1px solid #1e1e1e; border-radius: 0 10px 10px 0; }
  .ss-tcard:hover { background: #111; }

  .ss-tcard__img {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 4 / 3;
    background: linear-gradient(145deg, #111 0%, #161616 100%);
    border-bottom: 1px solid #1e1e1e;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }

  .ss-tcard__img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 60%, rgba(201,168,76,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .ss-tcard__img svg { opacity: 0.4; }

  .ss-tcard__content {
    padding: 1rem 1rem 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .ss-tcard__stars { color: #c9a84c; font-size: 0.65rem; letter-spacing: 0.12em; }

  .ss-tcard__quote {
    font-size: 0.75rem;
    color: #6a6a6a;
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .ss-tcard__author {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding-top: 0.8rem;
    border-top: 1px solid #181818;
    margin-top: auto;
  }

  .ss-tcard__avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #161410;
    border: 1px solid rgba(201,168,76,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.5rem;
    font-weight: 700;
    color: #c9a84c;
    flex-shrink: 0;
  }

  .ss-tcard__name { display: block; font-size: 0.68rem; font-weight: 600; color: #bbb; line-height: 1.2; }
  .ss-tcard__role { display: block; font-size: 0.58rem; color: #3a3a3a; margin-top: 0.1rem; }

  @media (max-width: 768px) {
    .ss-tcard { min-width: 220px; }
  }
{% endstylesheet %}

{% javascript %}
(function () {
  var countEl = document.getElementById('ss-countup');
  if (!countEl) return;
  var target = parseInt(countEl.getAttribute('data-target'), 10);
  var started = false;
  function easeOutQuart(t) { return 1 - Math.pow(1 - t, 4); }
  function runCount() {
    var start = performance.now();
    (function step(now) {
      var p = Math.min((now - start) / 1200, 1);
      countEl.textContent = Math.floor(easeOutQuart(p) * target).toLocaleString();
      if (p < 1) requestAnimationFrame(step);
      else countEl.textContent = target.toLocaleString();
    })(start);
  }
  new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting && !started) { started = true; runCount(); }
  }, { threshold: 0.4 }).observe(countEl);
})();
{% endjavascript %}
