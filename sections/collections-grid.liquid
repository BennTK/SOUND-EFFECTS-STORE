{%- comment -%}Collections Grid - Browse by Category{%- endcomment -%}

<section class="ss-collections">
  <div class="ss-collections__container">
    <div class="ss-collections__header">
      <p class="ss-section-eyebrow">Explore the Library</p>
      <h2 class="ss-section-title">Browse by Category</h2>
    </div>

    <div class="ss-collections__grid">

      <a href="/collections/sound-effects" class="ss-col-card ss-col-card--large">
        <div class="ss-col-card__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"></path>
          </svg>
        </div>
        <h3 class="ss-col-card__title">Sound Effects</h3>
        <p class="ss-col-card__desc">Drones, impacts, ambience, foley, and more. Every sound you need.</p>
        <span class="ss-col-card__cta">Browse →</span>
        <div class="ss-col-card__glow"></div>
      </a>

      <a href="/collections/soundtracks" class="ss-col-card">
        <div class="ss-col-card__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <path d="M9 18V5l12-2v13"></path>
            <circle cx="6" cy="18" r="3"></circle>
            <circle cx="18" cy="16" r="3"></circle>
          </svg>
        </div>
        <h3 class="ss-col-card__title">Soundtracks</h3>
        <p class="ss-col-card__desc">Cinematic scores and atmospheric music beds.</p>
        <span class="ss-col-card__cta">Browse →</span>
        <div class="ss-col-card__glow"></div>
      </a>

      <a href="/collections/bundles" class="ss-col-card">
        <div class="ss-col-card__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <polyline points="21 8 21 21 3 21 3 8"></polyline>
            <rect x="1" y="3" width="22" height="5"></rect>
            <line x1="10" y1="12" x2="14" y2="12"></line>
          </svg>
        </div>
        <h3 class="ss-col-card__title">Bundles</h3>
        <p class="ss-col-card__desc">Save more with curated multi-pack bundles.</p>
        <span class="ss-col-card__cta">Browse →</span>
        <div class="ss-col-card__glow"></div>
      </a>

      <a href="/collections/free" class="ss-col-card ss-col-card--accent">
        <div class="ss-col-card__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"></path>
          </svg>
        </div>
        <h3 class="ss-col-card__title">Free Samples</h3>
        <p class="ss-col-card__desc">Try before you buy — free sounds, no strings.</p>
        <span class="ss-col-card__cta">Get Free →</span>
        <div class="ss-col-card__glow"></div>
      </a>

    </div>
  </div>
</section>

{% stylesheet %}
  .ss-collections {
    background: #080808;
    padding: 6rem 2rem;
    border-top: 1px solid #161616;
  }

  .ss-collections__container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .ss-collections__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .ss-collections__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 1rem;
  }

  .ss-col-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2.5rem 2rem;
    background: #111;
    border: 1px solid #1e1e1e;
    border-radius: 6px;
    text-decoration: none;
    overflow: hidden;
    transition: border-color 0.25s, transform 0.25s;
  }

  .ss-col-card:hover {
    border-color: rgba(201,168,76,0.3);
    transform: translateY(-3px);
  }

  .ss-col-card--large {
    grid-row: 1;
  }

  .ss-col-card__icon {
    color: #c9a84c;
    margin-bottom: 0.5rem;
  }

  .ss-col-card__title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
  }

  .ss-col-card__desc {
    font-size: 0.85rem;
    color: #555;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .ss-col-card__cta {
    font-size: 0.75rem;
    color: #c9a84c;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-top: 0.5rem;
  }

  .ss-col-card__glow {
    position: absolute;
    bottom: -30px;
    left: -10px;
    width: 120px;
    height: 80px;
    background: radial-gradient(ellipse, rgba(201,168,76,0.06) 0%, transparent 70%);
    pointer-events: none;
    transition: opacity 0.3s;
    opacity: 0;
  }

  .ss-col-card:hover .ss-col-card__glow {
    opacity: 1;
  }

  .ss-col-card--accent {
    background: linear-gradient(145deg, #111 0%, #131108 100%);
    border-color: rgba(201,168,76,0.15);
  }

  @media (max-width: 900px) {
    .ss-collections__grid {
      grid-template-columns: 1fr 1fr;
    }
    .ss-col-card--large {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 540px) {
    .ss-collections__grid {
      grid-template-columns: 1fr;
    }
    .ss-col-card--large {
      grid-column: 1;
    }
  }
{% endstylesheet %}
