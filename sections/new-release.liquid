{%- comment -%}New Release Section - Sonority Sound{%- endcomment -%}

<section class="ss-nr">

  <div class="ss-nr__inner">

    <!-- NEW RELEASE label -->
    <div class="ss-nr__label">
      <span class="ss-nr__label-pulse"></span>
      <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      NEW RELEASE
    </div>

    <a href="/collections/sound-effects" class="ss-nr__layout">

      <!-- Photo slot -->
      <div class="ss-nr__photo">
        <div class="ss-nr__photo-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(0,0,0,0.15)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span>Add product photo</span>
        </div>
      </div>

      <!-- Text -->
      <div class="ss-nr__body">
        <p class="ss-nr__eyebrow">Drone Fly By Collection</p>
        <h2 class="ss-nr__title">Revolutionary Drone Fly By Sound Effects</h2>
        <p class="ss-nr__desc">Cinematic aerial audio captured from real drone fly-bys — engineered for film, games, and immersive media.</p>
        <p class="ss-nr__available">Now Available</p>
        <div class="ss-nr__actions">
          <span class="ss-nr__cta-btn">
            Shop the Drop
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          </span>
          <span class="ss-nr__preview">Preview samples &rarr;</span>
        </div>
      </div>

    </a>
  </div>
</section>

{% stylesheet %}
  .ss-nr {
    background: #ffffff;
    padding: 4rem 0 4.5rem;
    position: relative;
  }

  .ss-nr__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 3rem;
    position: relative;
  }

  /* NEW RELEASE label */
  .ss-nr__label {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: linear-gradient(90deg, #a07828 0%, #e8c96a 40%, #d4ac50 70%, #a07828 100%);
    color: #0a0a0a;
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    padding: 0.45rem 1rem;
    border-radius: 3px;
    margin-bottom: 2rem;
    box-shadow: 0 2px 12px rgba(201,168,76,0.35);
  }

  .ss-nr__label-pulse {
    width: 7px;
    height: 7px;
    background: #0a0a0a;
    border-radius: 50%;
    flex-shrink: 0;
    animation: ss-nr-pulse 1.8s ease-in-out infinite;
  }

  @keyframes ss-nr-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.6); }
  }

  /* Two-column layout */
  .ss-nr__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    text-decoration: none;
  }

  /* Photo slot */
  .ss-nr__photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #f2f2f2;
    border: 2px dashed #ddd;
    border-radius: 8px;
    overflow: hidden;
    position: relative;
  }

  .ss-nr__photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: #bbb;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  /* Text side */
  .ss-nr__body {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .ss-nr__eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c9a84c;
    margin: 0;
  }

  .ss-nr__title {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 900;
    color: #0a0a0a;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .ss-nr__desc {
    font-size: 1rem;
    color: #666;
    margin: 0;
    line-height: 1.7;
  }

  .ss-nr__available {
    font-size: 0.85rem;
    font-weight: 700;
    color: #c9a84c;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0;
  }

  .ss-nr__actions {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .ss-nr__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #0a0a0a;
    color: #fff;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.9rem 2rem;
    border-radius: 4px;
    transition: background 0.2s, transform 0.2s;
  }

  .ss-nr__layout:hover .ss-nr__cta-btn {
    background: #c9a84c;
    color: #0a0a0a;
    transform: translateX(3px);
  }

  .ss-nr__preview {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #aaa;
    transition: color 0.2s;
  }

  .ss-nr__layout:hover .ss-nr__preview {
    color: #666;
  }

  @media (max-width: 800px) {
    .ss-nr__layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .ss-nr__inner {
      padding: 0 1.5rem;
    }
  }
{% endstylesheet %}
