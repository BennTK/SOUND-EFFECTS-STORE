{% stylesheet %}
  .ss-showcases {
    background: #f5f5f5;
  }

  .ss-showcases__header {
    background: #ffffff;
    padding: 5rem 3rem 3rem;
    border-top: 1px solid #e8e8e8;
    border-bottom: 1px solid #e8e8e8;
  }

  .ss-showcases__header-inner {
    max-width: 1300px;
    margin: 0 auto;
    text-align: center;
  }

  .ss-showcases__header .ss-section-eyebrow { color: #c9a84c; }
  .ss-showcases__header .ss-section-title { color: #0a0a0a; }

  /* ── Each showcase ── */
  .ss-showcase {
    position: relative;
    background: #ffffff;
    border-bottom: 1px solid #e8e8e8;
    overflow: hidden;
  }

  /* Background image slot — full bleed behind all content */
  .ss-showcase__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .ss-showcase__bg-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.2);
    border: 2px dashed rgba(0,0,0,0.08);
  }

  /* Content sits above bg */
  .ss-showcase__inner {
    position: relative;
    z-index: 1;
    max-width: 1300px;
    margin: 0 auto;
    padding: 5rem 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* ── Text ── */
  .ss-showcase__body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ss-showcase__tag {
    display: inline-block;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #ffffff;
    background: #0a0a0a;
    padding: 0.3rem 0.75rem;
    border-radius: 2px;
    font-weight: 700;
    align-self: flex-start;
  }

  .ss-showcase__tag--value {
    background: #c9a84c;
    color: #0a0a0a;
  }

  .ss-showcase__eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c9a84c;
    margin: 0;
  }

  .ss-showcase__title {
    font-size: clamp(1.5rem, 2.2vw, 2.2rem);
    font-weight: 900;
    color: #0a0a0a;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .ss-showcase__desc {
    font-size: 0.88rem;
    color: #666;
    margin: 0;
    line-height: 1.7;
  }

  .ss-showcase__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .ss-showcase__features li {
    font-size: 0.8rem;
    color: #555;
    padding-left: 1.1rem;
    position: relative;
  }

  .ss-showcase__features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #c9a84c;
    font-weight: 700;
  }

  .ss-showcase__actions { margin-top: 0.25rem; }

  /* Buttons — consistent width */
  .ss-showcase__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.9rem 1.75rem;
    border-radius: 4px;
    text-decoration: none;
    min-width: 200px;
    transition: background 0.2s, transform 0.2s, color 0.2s, border-color 0.2s;
    box-sizing: border-box;
  }

  .ss-showcase__btn--full {
    width: 100%;
    min-width: 0;
  }

  .ss-showcase__btn--gold {
    background: #c9a84c;
    color: #0a0a0a;
  }

  .ss-showcase__btn--gold:hover { background: #e0bc6a; }

  .ss-showcase__btn--dark {
    background: #0a0a0a;
    color: #ffffff;
    border: 1px solid #0a0a0a;
  }

  .ss-showcase__btn--dark:hover {
    background: #c9a84c;
    color: #0a0a0a;
    border-color: #c9a84c;
  }

  /* ── Aside: photo + buy ── */
  .ss-showcase__aside {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ss-showcase__photo {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid #e0e0e0;
  }

  .ss-showcase__placeholder {
    width: 100%;
    height: 100%;
    background: #f2f2f2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: #bbb;
    text-transform: uppercase;
  }

  .ss-showcase__buy {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
  }

  .ss-showcase__price-note {
    font-size: 0.65rem;
    color: #aaa;
    text-align: center;
    margin: 0;
    letter-spacing: 0.04em;
  }

  /* ── Dual players wrapper ── */
  .ss-dual-players {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .ss-dual-players .ss-player__label {
    font-size: 0.63rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #888;
    margin: 0 0 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #ebebeb;
  }

  /* ── Inline Player (light theme) ── */
  .ss-player {
    display: flex;
    flex-direction: column;
  }

  .ss-player__label {
    font-size: 0.63rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #bbb;
    margin: 0 0 0.75rem;
  }

  .ss-player__tracks {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ss-player__track {
    display: grid;
    grid-template-columns: 30px 1fr auto;
    align-items: center;
    gap: 0.8rem;
    padding: 0.65rem 0.8rem;
    background: #f8f8f8;
    border: 1px solid #ebebeb;
    border-radius: 4px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }

  .ss-player__track:hover {
    background: #f2f2f2;
    border-color: #ddd;
  }

  .ss-player__track.is-active {
    border-color: rgba(201,168,76,0.4);
    background: #fdf9f0;
  }

  .ss-player__play {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 1px solid #ddd;
    background: #fff;
    color: #888;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    padding-left: 1px;
    transition: all 0.2s;
  }

  .ss-player__track.is-playing .ss-player__play {
    background: #c9a84c;
    border-color: #c9a84c;
    color: #fff;
  }

  .ss-player__play:hover {
    border-color: #c9a84c;
    color: #c9a84c;
  }

  .ss-player__info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .ss-player__name {
    font-size: 0.76rem;
    font-weight: 600;
    color: #444;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ss-player__track.is-active .ss-player__name { color: #0a0a0a; }

  .ss-player__pack {
    font-size: 0.6rem;
    color: #bbb;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ss-player__dur {
    font-size: 0.67rem;
    color: #bbb;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .ss-showcase__inner {
      grid-template-columns: 1fr;
      padding: 3.5rem 1.5rem;
    }
    .ss-showcases__header { padding: 4rem 1.5rem 2.5rem; }
    .ss-showcase__photo { aspect-ratio: 4 / 3; }
    .ss-showcase__btn { min-width: 0; width: 100%; }
  }
{% endstylesheet %}

{% javascript %}
(function () {
  document.querySelectorAll('.ss-player__track').forEach(function (row) {
    row.addEventListener('click', function () {
      var playerId = row.dataset.playerId;
      var isPlaying = row.classList.contains('is-playing');

      document.querySelectorAll('[data-player-id="' + playerId + '"]').forEach(function (r) {
        r.classList.remove('is-active', 'is-playing');
        r.querySelector('.ss-pi').style.display = '';
        r.querySelector('.ss-pau').style.display = 'none';
      });

      row.classList.add('is-active');

      if (!isPlaying) {
        row.classList.add('is-playing');
        row.querySelector('.ss-pi').style.display = 'none';
        row.querySelector('.ss-pau').style.display = '';
      }
    });
  });
})();
{% endjavascript %}
