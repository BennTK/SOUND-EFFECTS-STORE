{%- comment -%}Category Showcases — Sound Effects & Bundles{%- endcomment -%}

<section class="ss-showcases">

  <!-- Section header -->
  <div class="ss-showcases__header">
    <div class="ss-showcases__header-inner">
      <p class="ss-section-eyebrow">Explore the Store</p>
