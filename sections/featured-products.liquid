{%- comment -%}Category Showcases — Sound Effects & Bundles{%- endcomment -%}

<section class="ss-showcases">

  <!-- Section header -->
  <div class="ss-showcases__header">
    <div class="ss-showcases__header-inner">
      <p class="ss-section-eyebrow">Explore the Store</p>
      <h2 class="ss-section-title">Preview our high quality,<br>sound effects collections.</h2>
    </div>
  </div>

  <!-- Sound Effects -->
  <a href="/collections/sound-effects" class="ss-showcase ss-showcase--dark">
    <div class="ss-showcase__inner">
      <div class="ss-showcase__body">
        <p class="ss-showcase__eyebrow">500+ Professional Recordings</p>
        <h2 class="ss-showcase__title">Sound Effects<br>Built for Modern<br>Creators</h2>
        <p class="ss-showcase__desc">Drones, impacts, foley, ambience, and more — every sound professionally recorded and ready for film, games, podcasts, and beyond.</p>
        <ul class="ss-showcase__features">
          <li>Instant download, royalty-free</li>
          <li>Individual &amp; commercial licenses</li>
          <li>Organised &amp; metadata tagged</li>
        </ul>
        <div class="ss-showcase__actions">
          <span class="ss-showcase__btn ss-showcase__btn--gold">
            Browse Sound Effects
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          </span>
        </div>
      </div>
      <div class="ss-showcase__photo">
        <div class="ss-showcase__placeholder ss-showcase__placeholder--dark">
          <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span>Add collection photo</span>
        </div>
      </div>
    </div>
  </a>

  <!-- Bundles -->
  <a href="/collections/bundles" class="ss-showcase ss-showcase--warm">
    <div class="ss-showcase__inner ss-showcase__inner--flip">
      <div class="ss-showcase__photo">
        <div class="ss-showcase__placeholder ss-showcase__placeholder--warm">
          <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span>Add collection photo</span>
        </div>
      </div>
      <div class="ss-showcase__body">
        <div class="ss-showcase__tag">Best Value</div>
        <p class="ss-showcase__eyebrow">Save Up to 40%</p>
        <h2 class="ss-showcase__title">Curated Sound<br>Effect Bundles</h2>
        <p class="ss-showcase__desc">Multi-pack collections handpicked for filmmakers, game developers, and content creators. Get everything you need in one instant download.</p>
        <ul class="ss-showcase__features">
          <li>Massive savings vs individual packs</li>
          <li>Handpicked complementary sounds</li>
          <li>Commercial license included</li>
        </ul>
        <div class="ss-showcase__actions">
          <span class="ss-showcase__btn ss-showcase__btn--dark">
            Browse Bundles
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          </span>
        </div>
      </div>
    </div>
  </a>

</section>

{% stylesheet %}
  /* ── Header ── */
  .ss-showcases {
    background: #0a0a0a;
  }

  .ss-showcases__header {
    background: #0a0a0a;
    padding: 5rem 3rem 3rem;
    border-top: 1px solid #161616;
  }

  .ss-showcases__header-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  /* ── Each showcase row ── */
  .ss-showcase {
    display: block;
    text-decoration: none;
    padding: 5rem 0;
    border-top: 1px solid #161616;
    transition: opacity 0.2s;
  }

  .ss-showcase--dark {
    background: #0a0a0a;
  }

  .ss-showcase--warm {
    background: linear-gradient(180deg, #0d0c08 0%, #0a0a0a 100%);
  }

  .ss-showcase__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .ss-showcase__inner--flip {
    /* photo left, text right — natural DOM order handles it */
  }

  /* ── Text side ── */
  .ss-showcase__body {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    position: relative;
  }

  .ss-showcase__tag {
    display: inline-block;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0a0a0a;
    background: #c9a84c;
    padding: 0.3rem 0.75rem;
    border-radius: 2px;
    font-weight: 700;
    align-self: flex-start;
  }

  .ss-showcase__eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c9a84c;
    margin: 0;
  }

  .ss-showcase__title {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 900;
    color: #fff;
    margin: 0;
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .ss-showcase__desc {
    font-size: 0.95rem;
    color: #555;
    margin: 0;
    line-height: 1.7;
  }

  .ss-showcase__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ss-showcase__features li {
    font-size: 0.82rem;
    color: #666;
    padding-left: 1.1rem;
    position: relative;
  }

  .ss-showcase__features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #c9a84c;
    font-weight: 700;
  }

  .ss-showcase__actions {
    margin-top: 0.5rem;
  }

  .ss-showcase__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.9rem 2rem;
    border-radius: 4px;
    transition: background 0.2s, transform 0.2s, color 0.2s;
  }

  .ss-showcase__btn--gold {
    background: #c9a84c;
    color: #0a0a0a;
  }

  .ss-showcase--dark:hover .ss-showcase__btn--gold {
    background: #e0bc6a;
    transform: translateX(3px);
  }

  .ss-showcase__btn--dark {
    background: #0a0a0a;
    color: #fff;
    border: 1px solid #2a2a2a;
  }

  .ss-showcase--warm:hover .ss-showcase__btn--dark {
    background: #c9a84c;
    color: #0a0a0a;
    border-color: #c9a84c;
    transform: translateX(3px);
  }

  /* ── Photo slot ── */
  .ss-showcase__photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    overflow: hidden;
  }

  .ss-showcase__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
  }

  .ss-showcase__placeholder--dark {
    background: #111;
    border: 2px dashed #2a2a2a;
    border-radius: 8px;
    color: #333;
  }

  .ss-showcase__placeholder--warm {
    background: #131108;
    border: 2px dashed #2e2a18;
    border-radius: 8px;
    color: #3a3420;
  }

  /* ── Mobile ── */
  @media (max-width: 800px) {
    .ss-showcase__inner,
    .ss-showcase__inner--flip {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 0 1.5rem;
    }

    .ss-showcase__inner--flip .ss-showcase__photo {
      order: -1;
    }

    .ss-showcases__header {
      padding: 4rem 1.5rem 2.5rem;
    }
  }
{% endstylesheet %}
