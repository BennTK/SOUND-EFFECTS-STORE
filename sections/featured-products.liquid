    </div>
  </div>

  <!-- ── Sound Effects ── -->
  <div class="ss-showcase ss-showcase--dark">
    <div class="ss-showcase__inner">
      <div class="ss-showcase__body">
        <p class="ss-showcase__eyebrow">500+ Professional Recordings</p>
