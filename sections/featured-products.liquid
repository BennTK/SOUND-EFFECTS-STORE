{%- comment -%}Product Type Showcase - 3 category cards{%- endcomment -%}

<section class="ss-cats">
  <div class="ss-cats__container">

    <div class="ss-cats__header">
      <p class="ss-section-eyebrow">Explore the Store</p>
      <h2 class="ss-section-title">What are you looking for?</h2>
    </div>

    <div class="ss-cats__grid">

      <!-- Sound Effects -->
      <a href="/collections/sound-effects" class="ss-cat-card">
        <div class="ss-cat-card__bg ss-cat-card__bg--sfx">
          <div class="ss-cat-card__noise"></div>
          <div class="ss-cat-card__gradient"></div>
        </div>
        <div class="ss-cat-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <path d="M15.54 8.46a5 5 0 010 7.07"></path>
            <path d="M19.07 4.93a10 10 0 010 14.14"></path>
          </svg>
        </div>
        <div class="ss-cat-card__body">
          <span class="ss-cat-card__label">500+ Sounds</span>
          <h3 class="ss-cat-card__title">Sound Effects</h3>
          <p class="ss-cat-card__desc">Drones, impacts, foley, ambience & more. Professional-grade recordings for every scene.</p>
        </div>
        <div class="ss-cat-card__footer">
          <span class="ss-cat-card__cta">Browse Sound Effects <span class="ss-cat-card__arrow">→</span></span>
        </div>
      </a>

      <!-- Soundtracks -->
      <a href="/collections/soundtracks" class="ss-cat-card">
        <div class="ss-cat-card__bg ss-cat-card__bg--ost">
          <div class="ss-cat-card__noise"></div>
          <div class="ss-cat-card__gradient"></div>
        </div>
        <div class="ss-cat-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <path d="M9 18V5l12-2v13"></path>
            <circle cx="6" cy="18" r="3"></circle>
            <circle cx="18" cy="16" r="3"></circle>
          </svg>
        </div>
        <div class="ss-cat-card__body">
          <span class="ss-cat-card__label">Cinematic Scores</span>
          <h3 class="ss-cat-card__title">Soundtracks</h3>
          <p class="ss-cat-card__desc">Atmospheric scores and music beds crafted for film, documentary & YouTube.</p>
        </div>
        <div class="ss-cat-card__footer">
          <span class="ss-cat-card__cta">Browse Soundtracks <span class="ss-cat-card__arrow">→</span></span>
        </div>
      </a>

      <!-- Bundles -->
      <a href="/collections/bundles" class="ss-cat-card ss-cat-card--highlight">
        <div class="ss-cat-card__bg ss-cat-card__bg--bundle">
          <div class="ss-cat-card__noise"></div>
          <div class="ss-cat-card__gradient"></div>
        </div>
        <div class="ss-cat-card__tag">Best Value</div>
        <div class="ss-cat-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <polyline points="21 8 21 21 3 21 3 8"></polyline>
            <rect x="1" y="3" width="22" height="5"></rect>
            <line x1="10" y1="12" x2="14" y2="12"></line>
          </svg>
        </div>
        <div class="ss-cat-card__body">
          <span class="ss-cat-card__label">Save Up to 40%</span>
          <h3 class="ss-cat-card__title">Bundles</h3>
          <p class="ss-cat-card__desc">Curated multi-pack collections at a fraction of the price. Everything you need in one download.</p>
        </div>
        <div class="ss-cat-card__footer">
          <span class="ss-cat-card__cta">Browse Bundles <span class="ss-cat-card__arrow">→</span></span>
        </div>
      </a>

    </div>
  </div>
</section>

{% stylesheet %}
  .ss-cats {
    background: #0a0a0a;
    padding: 5rem 2rem;
    border-top: 1px solid #161616;
  }

  .ss-cats__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ss-cats__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .ss-cats__grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Card — 3840:2000 ≈ 1.92:1 aspect ratio */
  .ss-cat-card {
    position: relative;
    display: grid;
    grid-template-columns: 72px 1fr auto;
    grid-template-rows: 1fr auto;
    align-items: center;
    gap: 0 2rem;
    padding: 2.25rem 2.5rem;
    border-radius: 6px;
    border: 1px solid #1e1e1e;
    overflow: hidden;
    text-decoration: none;
    aspect-ratio: 389 / 67;
    transition: border-color 0.25s, transform 0.25s;
  }

  .ss-cat-card:hover {
    border-color: rgba(201,168,76,0.25);
    transform: translateY(-2px);
  }

  /* Backgrounds */
  .ss-cat-card__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .ss-cat-card__bg--sfx {
    background: linear-gradient(135deg, #0c0e14 0%, #111520 60%, #0d1018 100%);
  }

  .ss-cat-card__bg--ost {
    background: linear-gradient(135deg, #0e0c10 0%, #14101a 60%, #100d14 100%);
  }

  .ss-cat-card__bg--bundle {
    background: linear-gradient(135deg, #100e08 0%, #1a1608 60%, #12100a 100%);
  }

  .ss-cat-card__noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    background-size: 200px;
    opacity: 0.8;
  }

  .ss-cat-card__gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 50%, rgba(201,168,76,0.04) 0%, transparent 60%);
    transition: opacity 0.3s;
    opacity: 0;
  }

  .ss-cat-card:hover .ss-cat-card__gradient {
    opacity: 1;
  }

  /* Tag (Best Value) */
  .ss-cat-card__tag {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #0a0a0a;
    background: #c9a84c;
    padding: 0.3rem 0.75rem;
    border-radius: 2px;
    font-weight: 700;
    z-index: 1;
  }

  /* Icon */
  .ss-cat-card__icon {
    position: relative;
    z-index: 1;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(201,168,76,0.07);
    border: 1px solid rgba(201,168,76,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #c9a84c;
    flex-shrink: 0;
    transition: background 0.25s, border-color 0.25s;
  }

  .ss-cat-card:hover .ss-cat-card__icon {
    background: rgba(201,168,76,0.12);
    border-color: rgba(201,168,76,0.3);
  }

  /* Body */
  .ss-cat-card__body {
    position: relative;
    z-index: 1;
  }

  .ss-cat-card__label {
    display: block;
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c9a84c;
    margin-bottom: 0.4rem;
    font-weight: 500;
  }

  .ss-cat-card__title {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 800;
    color: #fff;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .ss-cat-card__desc {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.65;
    margin: 0;
    max-width: 480px;
  }

  /* Footer CTA */
  .ss-cat-card__footer {
    position: relative;
    z-index: 1;
    padding-left: 2rem;
    flex-shrink: 0;
  }

  .ss-cat-card__cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #444;
    white-space: nowrap;
    transition: color 0.2s;
  }

  .ss-cat-card:hover .ss-cat-card__cta {
    color: #c9a84c;
  }

  .ss-cat-card__arrow {
    transition: transform 0.2s;
  }

  .ss-cat-card:hover .ss-cat-card__arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .ss-cat-card {
      grid-template-columns: 48px 1fr;
      aspect-ratio: auto;
      padding: 1.75rem 1.5rem;
    }
    .ss-cat-card__footer {
      grid-column: 1 / -1;
      padding-left: 0;
      padding-top: 1rem;
      border-top: 1px solid #1a1a1a;
    }
    .ss-cat-card__tag {
      top: 1rem;
      right: 1rem;
    }
  }
{% endstylesheet %}
