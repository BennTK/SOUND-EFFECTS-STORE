{% stylesheet %}
  /* ── Header ── */
  .ss-showcases {
    background: #0a0a0a;
  }

  .ss-showcases__header {
    background: #0a0a0a;
    padding: 5rem 3rem 3rem;
    border-top: 1px solid #161616;
  }

  .ss-showcases__header-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  /* ── Each showcase row ── */
  .ss-showcase {
    display: block;
    padding: 5rem 0;
    border-top: 1px solid #161616;
  }

  .ss-showcase--dark {
    background: #0a0a0a;
  }

  .ss-showcase--warm {
    background: linear-gradient(180deg, #0d0c08 0%, #0a0a0a 100%);
  }

  .ss-showcase__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  /* ── Text side ── */
  .ss-showcase__body {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    position: relative;
  }

  .ss-showcase__tag {
    display: inline-block;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0a0a0a;
    background: #c9a84c;
    padding: 0.3rem 0.75rem;
    border-radius: 2px;
    font-weight: 700;
    align-self: flex-start;
  }

  .ss-showcase__eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c9a84c;
    margin: 0;
  }

  .ss-showcase__title {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 900;
    color: #fff;
    margin: 0;
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .ss-showcase__desc {
    font-size: 0.95rem;
    color: #555;
    margin: 0;
    line-height: 1.7;
  }

  .ss-showcase__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ss-showcase__features li {
    font-size: 0.82rem;
    color: #666;
    padding-left: 1.1rem;
    position: relative;
  }

  .ss-showcase__features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #c9a84c;
    font-weight: 700;
  }

  .ss-showcase__actions {
    margin-top: 0.25rem;
  }

  .ss-showcase__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.9rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s, color 0.2s, border-color 0.2s;
  }

  .ss-showcase__btn--gold {
    background: #c9a84c;
    color: #0a0a0a;
  }

  .ss-showcase__btn--gold:hover {
    background: #e0bc6a;
    transform: translateX(3px);
  }

  .ss-showcase__btn--dark {
    background: #0a0a0a;
    color: #fff;
    border: 1px solid #2a2a2a;
  }

  .ss-showcase__btn--dark:hover {
    background: #c9a84c;
    color: #0a0a0a;
    border-color: #c9a84c;
    transform: translateX(3px);
  }

  /* ── Photo slot ── */
  .ss-showcase__photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    overflow: hidden;
    position: sticky;
    top: 2rem;
  }

  .ss-showcase__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
  }

  .ss-showcase__placeholder--dark {
    background: #111;
    border: 2px dashed #2a2a2a;
    border-radius: 8px;
    color: #333;
  }

  .ss-showcase__placeholder--warm {
    background: #131108;
    border: 2px dashed #2e2a18;
    border-radius: 8px;
    color: #3a3420;
  }

  /* ── Inline Player ── */
  .ss-player {
    margin-top: 0.75rem;
    border-top: 1px solid #1a1a1a;
    padding-top: 1.25rem;
  }

  .ss-player__label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #3a3a3a;
    margin: 0 0 0.75rem;
  }

  .ss-player__tracks {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ss-player__track {
    display: grid;
    grid-template-columns: 32px 1fr auto;
    align-items: center;
    gap: 0.9rem;
    padding: 0.7rem 0.9rem;
    background: #0e0e0e;
    border: 1px solid #1a1a1a;
    border-radius: 4px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }

  .ss-player__track:hover {
    background: #131313;
    border-color: #222;
  }

  .ss-player__track.is-active {
    border-color: rgba(201,168,76,0.2);
    background: #110f08;
  }

  .ss-player__play {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid #252525;
    background: #181818;
    color: #666;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    padding-left: 1px;
    transition: all 0.2s;
  }

  .ss-player__track.is-playing .ss-player__play {
    background: #c9a84c;
    border-color: #c9a84c;
    color: #0a0a0a;
  }

  .ss-player__play:hover {
    border-color: rgba(201,168,76,0.5);
    color: #c9a84c;
  }

  .ss-player__info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .ss-player__name {
    font-size: 0.8rem;
    font-weight: 600;
    color: #888;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ss-player__track.is-active .ss-player__name {
    color: #ccc;
  }

  .ss-player__pack {
    font-size: 0.65rem;
    color: #2e2e2e;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ss-player__dur {
    font-size: 0.7rem;
    color: #2e2e2e;
    font-variant-numeric: tabular-nums;
  }

  /* ── Mobile ── */
  @media (max-width: 800px) {
    .ss-showcase__inner,
    .ss-showcase__inner--flip {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 0 1.5rem;
    }

    .ss-showcase__inner--flip .ss-showcase__photo {
      order: -1;
    }

    .ss-showcase__photo {
      position: static;
    }

    .ss-showcases__header {
      padding: 4rem 1.5rem 2.5rem;
    }

    .ss-showcase {
      padding: 3.5rem 0;
    }
  }
{% endstylesheet %}

{% javascript %}
(function () {
  var allTracks = document.querySelectorAll('.ss-player__track');

  allTracks.forEach(function (row) {
    row.addEventListener('click', function (e) {
      var playerId = row.dataset.playerId;
      var isPlaying = row.classList.contains('is-playing');

      /* reset all tracks in same player group */
      document.querySelectorAll('[data-player-id="' + playerId + '"]').forEach(function (r) {
        r.classList.remove('is-active', 'is-playing');
        r.querySelector('.ss-pi').style.display = '';
        r.querySelector('.ss-pau').style.display = 'none';
      });

      row.classList.add('is-active');

      if (!isPlaying) {
        row.classList.add('is-playing');
        row.querySelector('.ss-pi').style.display = 'none';
        row.querySelector('.ss-pau').style.display = '';
      }
    });
  });
})();
{% endjavascript %}
