              </div>
              <span class="ss-player__dur">0:42</span>
            </div>
            <div class="ss-player__track" data-player-id="sfx" data-track="1">
              <button class="ss-player__play" aria-label="Play">
                <svg class="ss-pi" width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
                <svg class="ss-pau" width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
              </button>
              <div class="ss-player__info">
                <span class="ss-player__name">Impact Strike &mdash; Heavy</span>
                <span class="ss-player__pack">Cinematic Hits Pack</span>
              </div>
              <span class="ss-player__dur">0:22</span>
            </div>
            <div class="ss-player__track" data-player-id="sfx" data-track="2">
              <button class="ss-player__play" aria-label="Play">
                <svg class="ss-pi" width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
                <svg class="ss-pau" width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
              </button>
