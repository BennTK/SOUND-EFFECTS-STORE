{% stylesheet %}
  .ss-proof {
    background: #0a0a0a;
    padding-top: 3rem;
    border-top: 1px solid #161616;
  }

  .ss-proof__container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .ss-proof__headline {
    text-align: center;
    margin-bottom: 2rem;
  }

  .ss-proof__number {
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 900;
    color: #fff;
    margin: 0 0 0.5rem;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .ss-proof__tagline {
    color: #555;
    margin: 0 0 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
  }

  .ss-proof__stars {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: #c9a84c;
    font-size: 1.4rem;
  }

  .ss-proof__rating-text {
    font-size: 0.8rem;
    color: #555;
    letter-spacing: 0.05em;
  }

  /* ── Carousel ── */
  .ss-carousel-outer {
    position: relative;
  }

  .ss-carousel-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 1.5rem 0;
  }

  .ss-carousel-viewport {
    width: 100%;
    overflow: hidden;
    perspective: 1200px;
    perspective-origin: 50% 50%;
  }

  .ss-carousel-track {
    display: flex;
    gap: 1.5rem;
    padding: 1rem 2rem;
    will-change: transform;
  }

  .ss-tcard {
    flex: 0 0 360px;
    background: #111;
    border: 1px solid #1e1e1e;
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .ss-tcard:hover { border-color: #2a2a2a; }

  .ss-tcard__img {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: linear-gradient(145deg, #0e0e0e, #161616);
    border: 1px solid #1e1e1e;
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }

  .ss-tcard__stars { color: #c9a84c; font-size: 0.85rem; letter-spacing: 0.1em; }

  .ss-tcard__quote {
    font-size: 0.9rem;
    color: #888;
    line-height: 1.75;
    margin: 0;
    font-style: italic;
    flex: 1;
  }

  .ss-tcard__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid #1a1a1a;
  }

  .ss-tcard__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1e1a0e, #2d2510);
    border: 1px solid rgba(201,168,76,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    color: #c9a84c;
    flex-shrink: 0;
  }

  .ss-tcard__name { display: block; font-size: 0.8rem; font-weight: 600; color: #ccc; }
  .ss-tcard__role { display: block; font-size: 0.7rem; color: #444; margin-top: 0.1rem; }

  .ss-carousel-dots { display: flex; gap: 0.5rem; margin-top: 2rem; }

  .ss-carousel-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #2a2a2a;
    transition: background 0.3s, transform 0.3s;
  }

  .ss-carousel-dot.active { background: #c9a84c; transform: scale(1.3); }

  /* Reels */
  .ss-reels { margin-bottom: 4rem; padding-top: 3.5rem; border-top: 1px solid #161616; }

  .ss-reels__header { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 1.75rem; }

  .ss-reels__label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; color: #555; }

  .ss-reels__grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 0.75rem; }

  .ss-reel { text-decoration: none; display: flex; flex-direction: column; gap: 0.5rem; }

  .ss-reel__thumb {
    position: relative;
    aspect-ratio: 1;
    background: #111;
    border: 1px solid #1e1e1e;
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .ss-reel:hover .ss-reel__thumb { border-color: rgba(201,168,76,0.3); }

  .ss-reel__placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(145deg, #111 0%, #161616 100%);
  }

  .ss-reel__overlay {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0,0,0,0.4);
    opacity: 0; transition: opacity 0.2s;
  }

  .ss-reel:hover .ss-reel__overlay { opacity: 1; }

  .ss-reel__caption { font-size: 0.7rem; color: #444; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  /* Trust badges */
  .ss-proof__badges {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
    padding: 3rem 0 5rem;
    border-top: 1px solid #161616;
  }

  .ss-proof__badge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-align: center;
  }

  .ss-proof__badge-item--license {
    background: #111;
    border: 1px solid #1e1e1e;
    border-radius: 5px;
    padding: 1.25rem 1.75rem;
    gap: 0.5rem;
  }

  .ss-badge__title { font-size: 0.75rem; color: #ccc; font-weight: 600; letter-spacing: 0.08em; }
  .ss-badge__sub { font-size: 0.65rem; color: #444; text-transform: none; letter-spacing: 0.03em; font-weight: 400; }

  .ss-proof__badges-divider { width: 1px; height: 48px; background: #1e1e1e; align-self: center; }

  @media (max-width: 768px) {
    .ss-carousel-sticky { height: auto; position: relative; padding: 2rem 0; }
    .ss-carousel-outer { height: auto !important; }
    .ss-tcard { flex: 0 0 280px; }
    .ss-reels__grid { grid-template-columns: repeat(3, 1fr); }
    .ss-proof__badges { gap: 2rem; }
  }

  @media (max-width: 480px) {
    .ss-reels__grid { grid-template-columns: repeat(2, 1fr); }
  }
{% endstylesheet %}

{% javascript %}
(function () {

  /* ── Count-up ── */
  var countEl = document.getElementById('ss-countup');
  if (countEl) {
    var target   = parseInt(countEl.getAttribute('data-target'), 10);
    var duration = 1200;
    var started  = false;

    function easeOutQuart(t) { return 1 - Math.pow(1 - t, 4); }

    function runCount() {
      var start = performance.now();
      (function step(now) {
        var p = Math.min((now - start) / duration, 1);
        countEl.textContent = Math.floor(easeOutQuart(p) * target).toLocaleString();
        if (p < 1) requestAnimationFrame(step);
        else countEl.textContent = target.toLocaleString();
      })(start);
    }

    var countObs = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting && !started) { started = true; runCount(); countObs.disconnect(); }
    }, { threshold: 0.4 });
    countObs.observe(countEl);
  }

  /* ── Scroll-locked carousel ── */
  var outer = document.getElementById('ss-carousel-outer');
  var track = document.getElementById('ss-carousel-track');
  var dots  = document.querySelectorAll('.ss-carousel-dot');

  if (!outer || !track) return;

  if (window.innerWidth <= 768) return;

  var cardW     = 360 + 24;
  var cardCount = track.children.length;
  var overflow  = 0;

  function setup() {
    var viewW = outer.offsetWidth;
    overflow  = Math.max(0, cardCount * cardW - viewW);
    outer.style.height = (window.innerHeight + overflow) + 'px';
  }

  function onScroll() {
    var rect     = outer.getBoundingClientRect();
    var scrolled = -rect.top;
    var progress = Math.max(0, Math.min(1, scrolled / overflow));
    var tx       = -(progress * overflow);

    track.style.transform = 'translateX(' + tx + 'px)';

    var viewCX = window.innerWidth / 2;
    var cards  = track.querySelectorAll('.ss-tcard');
    cards.forEach(function(card) {
      var r      = card.getBoundingClientRect();
      var cardCX = r.left + r.width / 2;
      var dist   = cardCX - viewCX;
      var maxD   = window.innerWidth * 0.6;
      var ratio  = Math.max(-1, Math.min(1, dist / maxD));
      var rotY   = ratio * 28;
      var rotX   = Math.abs(ratio) * -6;
      var scale  = 1 - Math.abs(ratio) * 0.08;
      var fadeZ  = Math.abs(ratio) * -60;
      card.style.transform =
        'perspective(900px) translateZ(' + fadeZ + 'px) rotateY(' + rotY + 'deg) rotateX(' + rotX + 'deg) scale(' + scale + ')';
      card.style.opacity = 1 - Math.abs(ratio) * 0.4;
    });

    var step   = overflow / (cardCount - 1);
    var active = Math.round((progress * overflow) / step);
    dots.forEach(function(d, i) { d.classList.toggle('active', i === active); });
  }

  setup();
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', function() { setup(); onScroll(); });
  onScroll();

})();
{% endjavascript %}
