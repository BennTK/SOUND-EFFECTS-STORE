{%- comment -%}Social Proof Section — Sonority Sound{%- endcomment -%}

<section class="ss-proof">
  <div class="ss-proof__container">

    <!-- Big stat -->
    <div class="ss-proof__headline">
      <h2 class="ss-proof__number"><span id="ss-countup" data-target="1243">0</span>+</h2>
      <p class="ss-proof__tagline">Creators Trust Sonority Sound</p>
      <div class="ss-proof__stars">
        <span>★★★★★</span>
        <span class="ss-proof__rating-text">4.9 out of 5 &bull; 318 reviews</span>
      </div>
    </div>

  </div>

  <!-- Testimonials grid -->
  <div class="ss-testimonials">
    <div class="ss-testimonials__grid">

      <div class="ss-tcard">
        <div class="ss-tcard__stars">★★★★★</div>
        <p class="ss-tcard__quote">"The Drone Fly By pack saved my documentary edit. Incredible depth and clarity — sounds you simply can't get anywhere else."</p>
        <div class="ss-tcard__author">
          <div class="ss-tcard__avatar">JR</div>
          <div>
            <span class="ss-tcard__name">James R.</span>
            <span class="ss-tcard__role">Documentary Filmmaker</span>
          </div>
        </div>
      </div>

      <div class="ss-tcard">
        <div class="ss-tcard__stars">★★★★★</div>
        <p class="ss-tcard__quote">"I've tried every major SFX library. Sonority Sound is in a different league — cinema-grade quality at a fraction of the price."</p>
        <div class="ss-tcard__author">
          <div class="ss-tcard__avatar">MT</div>
          <div>
            <span class="ss-tcard__name">Maya T.</span>
            <span class="ss-tcard__role">Game Audio Designer</span>
          </div>
        </div>
      </div>

      <div class="ss-tcard">
        <div class="ss-tcard__stars">★★★★★</div>
        <p class="ss-tcard__quote">"Instant download, perfectly organised files, commercial license — everything a professional needs. My go-to for every project now."</p>
        <div class="ss-tcard__author">
          <div class="ss-tcard__avatar">AL</div>
          <div>
            <span class="ss-tcard__name">Alex L.</span>
            <span class="ss-tcard__role">YouTube Creator &mdash; 800K subs</span>
          </div>
        </div>
      </div>

      <div class="ss-tcard">
        <div class="ss-tcard__stars">★★★★★</div>
        <p class="ss-tcard__quote">"Used the Momentum pack on a brand campaign for a major client. The client thought we had a full sound team. Game changer."</p>
        <div class="ss-tcard__author">
          <div class="ss-tcard__avatar">CW</div>
          <div>
            <span class="ss-tcard__name">Chris W.</span>
            <span class="ss-tcard__role">Creative Director</span>
          </div>
        </div>
      </div>

      <div class="ss-tcard">
        <div class="ss-tcard__stars">★★★★★</div>
        <p class="ss-tcard__quote">"As an indie game dev working solo, these packs are a lifesaver. The quality is indistinguishable from custom-recorded audio."</p>
        <div class="ss-tcard__author">
          <div class="ss-tcard__avatar">NP</div>
          <div>
            <span class="ss-tcard__name">Nina P.</span>
            <span class="ss-tcard__role">Indie Game Developer</span>
          </div>
        </div>
      </div>

      <div class="ss-tcard">
        <div class="ss-tcard__stars">★★★★★</div>
        <p class="ss-tcard__quote">"I've been in post-production for 12 years. Sonority Sound consistently delivers what others promise but rarely achieve."</p>
        <div class="ss-tcard__author">
          <div class="ss-tcard__avatar">DO</div>
          <div>
            <span class="ss-tcard__name">David O.</span>
            <span class="ss-tcard__role">Post-Production Supervisor</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div class="ss-proof__container">

    <!-- Instagram Reels -->
    <div class="ss-reels">
      <div class="ss-reels__header">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path><circle cx="17.5" cy="6.5" r="1.5" fill="#c9a84c" stroke="none"></circle></svg>
        <span class="ss-reels__label">Made with Sonority Sound</span>
      </div>
      <div class="ss-reels__grid">
        {% for i in (1..6) %}
          <a href="#" target="_blank" rel="noopener" class="ss-reel">
            <div class="ss-reel__thumb">
              <div class="ss-reel__placeholder">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.2"><polygon points="5,3 19,12 5,21"></polygon></svg>
              </div>
              <div class="ss-reel__overlay">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><polygon points="5,3 19,12 5,21"></polygon></svg>
              </div>
            </div>
            <p class="ss-reel__caption">@creator &bull; Add caption</p>
          </a>
        {% endfor %}
      </div>
    </div>

    <!-- Trust badges -->
    <div class="ss-proof__badges">

      <div class="ss-proof__badge-item ss-proof__badge-item--license">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        <span class="ss-badge__title">Individual License</span>
        <span class="ss-badge__sub">Personal &amp; solo creator use</span>
      </div>

      <div class="ss-proof__badges-divider"></div>

      <div class="ss-proof__badge-item ss-proof__badge-item--license">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span class="ss-badge__title">Commercial License</span>
        <span class="ss-badge__sub">Teams, agencies &amp; brands</span>
      </div>

      <div class="ss-proof__badges-divider"></div>

      <div class="ss-proof__badge-item">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
        <span>Instant Download</span>
      </div>
      <div class="ss-proof__badge-item">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span>30-Day Guarantee</span>
      </div>
      <div class="ss-proof__badge-item">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>24/7 Support</span>
      </div>
    </div>

  </div>
</section>

{% stylesheet %}
  .ss-proof {
    background: #0a0a0a;
    padding-top: 3rem;
    border-top: 1px solid #161616;
  }

  .ss-proof__container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .ss-proof__headline {
    text-align: center;
    margin-bottom: 2rem;
  }

  .ss-proof__number {
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 900;
    color: #fff;
    margin: 0 0 0.5rem;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .ss-proof__tagline {
    color: #555;
    margin: 0 0 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
  }

  .ss-proof__stars {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: #c9a84c;
    font-size: 1.4rem;
  }

  .ss-proof__rating-text {
    font-size: 0.8rem;
    color: #555;
    letter-spacing: 0.05em;
  }

  /* ── Testimonials Row ── */
  .ss-testimonials {
    padding: 0 0 3.5rem;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .ss-testimonials::-webkit-scrollbar { display: none; }

  .ss-testimonials__grid {
    display: flex;
    gap: 0;
    padding: 0 2rem;
    min-width: max-content;
  }

  .ss-tcard {
    width: 300px;
    flex-shrink: 0;
    background: #0e0e0e;
    border: 1px solid #1e1e1e;
    border-right: none;
    padding: 1.4rem 1.4rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    transition: background 0.2s;
  }

  .ss-tcard:first-child { border-radius: 8px 0 0 8px; }
  .ss-tcard:last-child  { border-right: 1px solid #1e1e1e; border-radius: 0 8px 8px 0; }

  .ss-tcard:hover { background: #111; }

  .ss-tcard__stars {
    color: #c9a84c;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
  }

  .ss-tcard__quote {
    font-size: 0.82rem;
    color: #777;
    line-height: 1.7;
    margin: 0;
    flex: 1;
  }

  .ss-tcard__author {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding-top: 0.9rem;
    border-top: 1px solid #181818;
    margin-top: auto;
  }

  .ss-tcard__avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: #161410;
    border: 1px solid rgba(201,168,76,0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.58rem;
    font-weight: 700;
    color: #c9a84c;
    flex-shrink: 0;
    letter-spacing: 0.03em;
  }

  .ss-tcard__name {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: #bbb;
    line-height: 1.2;
  }

  .ss-tcard__role {
    display: block;
    font-size: 0.65rem;
    color: #3d3d3d;
    margin-top: 0.15rem;
  }

  /* Reels */
  .ss-reels {
    margin-bottom: 4rem;
    padding-top: 3.5rem;
    border-top: 1px solid #161616;
  }

  .ss-reels__header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.75rem;
  }

  .ss-reels__label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #555;
  }

  .ss-reels__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.75rem;
  }

  .ss-reel { text-decoration: none; display: flex; flex-direction: column; gap: 0.5rem; }

  .ss-reel__thumb {
    position: relative;
    aspect-ratio: 1;
    background: #111;
    border: 1px solid #1e1e1e;
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .ss-reel:hover .ss-reel__thumb { border-color: rgba(201,168,76,0.3); }

  .ss-reel__placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(145deg, #111 0%, #161616 100%);
  }

  .ss-reel__overlay {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0,0,0,0.4);
    opacity: 0; transition: opacity 0.2s;
  }

  .ss-reel:hover .ss-reel__overlay { opacity: 1; }

  .ss-reel__caption { font-size: 0.7rem; color: #444; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  /* Trust badges */
  .ss-proof__badges {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
    padding: 3rem 0 5rem;
    border-top: 1px solid #161616;
  }

  .ss-proof__badge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-align: center;
  }

  .ss-proof__badge-item--license {
    background: #111;
    border: 1px solid #1e1e1e;
    border-radius: 5px;
    padding: 1.25rem 1.75rem;
    gap: 0.5rem;
  }

  .ss-badge__title { font-size: 0.75rem; color: #ccc; font-weight: 600; letter-spacing: 0.08em; }
  .ss-badge__sub { font-size: 0.65rem; color: #444; text-transform: none; letter-spacing: 0.03em; font-weight: 400; }

  .ss-proof__badges-divider {
    width: 1px; height: 48px;
    background: #1e1e1e;
    align-self: center;
  }

  @media (max-width: 768px) {
    .ss-tcard { width: 260px; }
    .ss-reels__grid { grid-template-columns: repeat(3, 1fr); }
    .ss-proof__badges { gap: 2rem; }
  }

  @media (max-width: 480px) {
    .ss-reels__grid { grid-template-columns: repeat(2, 1fr); }
  }
{% endstylesheet %}

{% javascript %}
(function () {

  /* ── Count-up ── */
  var countEl = document.getElementById('ss-countup');
  if (countEl) {
    var target   = parseInt(countEl.getAttribute('data-target'), 10);
    var duration = 1200;
    var started  = false;

    function easeOutQuart(t) { return 1 - Math.pow(1 - t, 4); }

    function runCount() {
      var start = performance.now();
      (function step(now) {
        var p = Math.min((now - start) / duration, 1);
        countEl.textContent = Math.floor(easeOutQuart(p) * target).toLocaleString();
        if (p < 1) requestAnimationFrame(step);
        else countEl.textContent = target.toLocaleString();
      })(start);
    }

    var countObs = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting && !started) { started = true; runCount(); countObs.disconnect(); }
    }, { threshold: 0.4 });
    countObs.observe(countEl);
  }


})();
{% endjavascript %}
