  var ML_GROUP = '189766928641820360';

  var form        = document.getElementById('cs-signup-form');
  var input       = document.getElementById('cs-email-input');
  var btn         = document.getElementById('cs-submit-btn');
  var msg         = document.getElementById('cs-form-msg');
  var successCard = document.getElementById('cs-success-card');

  if (!form) return;

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var email = input.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      msg.textContent = 'Please enter a valid email address.';
      msg.className = 'cs-form-msg cs-form-msg--error';
      return;
    }
    btn.disabled = true;
    btn.textContent = 'Sending…';
    msg.textContent = '';

    fetch('https://connect.mailerlite.com/api/subscribers', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + ML_TOKEN },
      body: JSON.stringify({ email: email, groups: [ML_GROUP] })
    })
    .then(function (res) {
      if (res.status === 200 || res.status === 201 || res.status === 409) {
        form.style.display = 'none';
        msg.textContent = '';
        successCard.classList.add('show');
      } else { throw new Error(); }
    })
    .catch(function () {
      btn.disabled = false;
      btn.textContent = 'Notify Me';
      msg.textContent = 'Something went wrong — please try again.';
      msg.className = 'cs-form-msg cs-form-msg--error';
    });
  });
})();
